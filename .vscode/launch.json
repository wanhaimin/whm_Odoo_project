{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Odoo: Run (Local)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/odoo/odoo-bin",
            "args": [
                "-c",
                "${workspaceFolder}/odoo.conf",
                "-u",
                "my_material_list"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "GEVENT_SUPPORT": "True"
            },
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}