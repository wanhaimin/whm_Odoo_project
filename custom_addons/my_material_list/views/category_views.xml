<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Detailed View for Category -->
    <record id="view_my_material_category_form" model="ir.ui.view">
        <field name="name">my.material.category.form</field>
        <field name="model">my.material.category</field>
        <field name="arch" type="xml">
            <form string="Material Category">
                <sheet>
                    <group>
                        <field name="name" string="分类名称"/>
                        <field name="description" string="描述"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_my_material_category_tree" model="ir.ui.view">
        <field name="name">my.material.category.tree</field>
        <field name="model">my.material.category</field>
        <field name="arch" type="xml">
            <list string="Material Categories" multi_edit="1">
                <field name="name" string="分类名称" width="200px"/>
                <field name="description" string="描述" width="400px"/>
            </list>
        </field>
    </record>

    <record id="action_my_material_category" model="ir.actions.act_window">
        <field name="name">材料类别</field>
        <field name="res_model">my.material.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
