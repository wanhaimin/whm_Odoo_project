<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_diecut_kb_article_search" model="ir.ui.view">
        <field name="name">diecut.kb.article.search</field>
        <field name="model">diecut.kb.article</field>
        <field name="arch" type="xml">
            <search string="搜索知识文章">
                <field name="name" string="标题"/>
                <field name="summary"/>
                <field name="content_text" string="正文"/>
                <field name="keywords"/>
                <field name="category_id"/>
                <field name="related_brand_ids"/>
                <field name="related_categ_ids"/>
                <field name="related_item_ids"/>
                <field name="related_article_ids"/>
                <field name="compile_source_document_id"/>
                <field name="author_name"/>
                <separator/>
                <filter string="收藏" name="favorite" domain="[('is_favorite','=',True)]"/>
                <filter string="草稿" name="draft" domain="[('state','=','draft')]"/>
                <filter string="评审中" name="review" domain="[('state','=','review')]"/>
                <filter string="已发布" name="published" domain="[('state','=','published')]"/>
                <filter string="已归档" name="archived" domain="[('state','=','archived')]"/>
                <separator/>
                <filter string="待同步" name="sync_pending" domain="[('sync_status','=','pending')]"/>
                <filter string="同步失败" name="sync_failed" domain="[('sync_status','=','failed')]"/>
                <filter string="AI 编译" name="ai_compiled" domain="[('compile_source','!=','manual')]"/>
                <separator/>
                <filter string="按分类分组" name="group_category" context="{'group_by':'category_id'}"/>
                <filter string="按状态分组" name="group_state" context="{'group_by':'state'}"/>
                <filter string="按同步状态分组" name="group_sync" context="{'group_by':'sync_status'}"/>
                <filter string="按来源分组" name="group_compile_source" context="{'group_by':'compile_source'}"/>
            </search>
        </field>
    </record>

    <record id="view_diecut_kb_article_list" model="ir.ui.view">
        <field name="name">diecut.kb.article.list</field>
        <field name="model">diecut.kb.article</field>
        <field name="arch" type="xml">
            <list string="知识文章" sample="1" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="compile_source" optional="hide"/>
                <field name="compile_risk_level" widget="badge" optional="show"
                       decoration-success="compile_risk_level == 'low'"
                       decoration-warning="compile_risk_level == 'medium'"
                       decoration-danger="compile_risk_level == 'high'"/>
                <field name="compile_confidence" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'review'"
                       decoration-success="state == 'published'"
                       decoration-muted="state == 'archived'"/>
                <field name="sync_status" widget="badge"
                       decoration-info="sync_status == 'pending'"
                       decoration-success="sync_status == 'synced'"
                       decoration-danger="sync_status == 'failed'"
                       decoration-muted="sync_status == 'skipped'"/>
                <field name="lint_issue_count" optional="hide"/>
                <field name="content_length" string="字数"/>
                <field name="attachment_count" string="附件"/>
                <field name="author_name"/>
                <field name="publish_date"/>
                <field name="last_edited_at"/>
                <field name="last_edited_uid" optional="hide"/>
                <field name="is_favorite" widget="boolean_favorite"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_kb_article_kanban" model="ir.ui.view">
        <field name="name">diecut.kb.article.kanban</field>
        <field name="model">diecut.kb.article</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id" sample="1">
                <field name="category_id"/>
                <field name="state"/>
                <field name="sync_status"/>
                <field name="is_favorite"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <field name="is_favorite" widget="boolean_favorite"/>
                            </div>
                            <div class="o_kanban_tags_section">
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'draft':'default','review':'warning','published':'success','archived':'muted'}}"/>
                                <field name="sync_status" widget="label_selection"
                                       options="{'classes': {'pending':'info','synced':'success','failed':'danger','skipped':'muted'}}"/>
                            </div>
                            <div t-if="record.summary.raw_value" class="text-muted small mt-2">
                                <field name="summary"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="author_name"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="publish_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_diecut_kb_article_form" model="ir.ui.view">
        <field name="name">diecut.kb.article.form</field>
        <field name="model">diecut.kb.article</field>
        <field name="arch" type="xml">
            <form string="知识文章">
                <header>
                    <button name="action_submit_review" type="object" string="提交评审"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_publish" type="object" string="发布"
                            class="oe_highlight" invisible="state not in ('draft','review')"/>
                    <button name="action_back_to_draft" type="object" string="退回草稿"
                            invisible="state == 'draft'"/>
                    <button name="action_archive_article" type="object" string="归档"
                            invisible="state == 'archived'"/>
                    <button name="action_fill_content_from_attachments" type="object" string="从附件填充正文"
                            invisible="state == 'archived'"
                            help="把已解析的附件文本追加到正文末尾，不会覆盖已有内容。"/>
                    <button name="action_request_sync" type="object" string="立即同步到 Dify"
                            invisible="state != 'published'"/>
                    <button name="action_mark_pending" type="object" string="加入同步队列"
                            invisible="state != 'published'"/>
                    <button name="action_recompile" type="object" string="重新编译"
                            class="btn-secondary" icon="fa-magic"
                            invisible="not compile_source_item_id and not compile_source_document_id"/>
                    <button name="action_run_lint" type="object" string="治理检查"
                            class="btn-secondary" icon="fa-stethoscope"/>
                    <button name="action_open_ai_advisor" type="object" string="AI 顾问"
                            class="btn-primary" icon="fa-comments"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,published"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments" type="object" class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="附件"/>
                        </button>
                        <button name="action_view_sync_logs" type="object" class="oe_stat_button" icon="fa-history">
                            <span class="o_stat_text">同步日志</span>
                        </button>
                        <field name="is_favorite" widget="boolean_favorite" nolabel="1"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="例如：3M VHB 选型指南（电子产品）"/></h1>
                        <field name="summary" placeholder="一句话概括这篇文章的核心内容..."/>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="parent_id" options="{'no_create': True}"/>
                            <field name="keywords" placeholder="逗号分隔，如：VHB,选型,泡棉"/>
                        </group>
                        <group>
                            <field name="author_name"/>
                            <field name="source_url" widget="url"/>
                            <field name="publish_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="正文" name="content">
                            <field name="content_html" placeholder="正文内容，支持富文本..."/>
                        </page>
                        <page string="关联">
                            <group>
                                <field name="related_brand_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                                <field name="related_categ_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                                <field name="related_item_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                                <field name="related_article_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                            </group>
                        </page>
                        <page string="附件">
                            <field name="attachment_ids" mode="list">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="file_data" filename="file_name" widget="binary"/>
                                    <field name="file_name" optional="hide"/>
                                    <field name="attachment_kind"/>
                                    <field name="needs_ocr"/>
                                    <field name="parse_state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="子文章">
                            <field name="child_ids" mode="list">
                                <list>
                                    <field name="name"/>
                                    <field name="state" widget="badge"/>
                                    <field name="last_edited_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="同步信息" groups="base.group_system">
                            <group>
                                <group>
                                    <field name="sync_status"/>
                                    <field name="last_sync_at"/>
                                    <field name="content_length"/>
                                    <field name="compile_source"/>
                                    <field name="compile_source_document_id"/>
                                    <field name="compile_source_item_id"/>
                                    <field name="compile_confidence"/>
                                    <field name="compile_risk_level"/>
                                </group>
                                <group>
                                    <field name="dify_dataset_id"/>
                                    <field name="dify_document_id"/>
                                    <field name="compiled_at"/>
                                    <field name="compiled_hash"/>
                                    <field name="source_file_name"/>
                                    <field name="source_page_refs"/>
                                    <field name="xref_enriched_at"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="last_linted_at"/>
                                    <field name="lint_issue_count"/>
                                </group>
                                <group/>
                            </group>
                            <group string="错误信息" invisible="not sync_error">
                                <field name="sync_error" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_kb_article_batch_sync" model="ir.actions.server">
        <field name="name">立即同步到 Dify</field>
        <field name="model_id" ref="model_diecut_kb_article"/>
        <field name="binding_model_id" ref="model_diecut_kb_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_request_sync()</field>
    </record>

    <record id="action_kb_article_batch_mark_pending" model="ir.actions.server">
        <field name="name">加入同步队列</field>
        <field name="model_id" ref="model_diecut_kb_article"/>
        <field name="binding_model_id" ref="model_diecut_kb_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_mark_pending()</field>
    </record>

    <record id="action_diecut_kb_article" model="ir.actions.act_window">
        <field name="name">知识文章</field>
        <field name="res_model">diecut.kb.article</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_diecut_kb_article_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">创建第一篇行业知识文章</p>
            <p>把材料选型经验、模切工艺、刀模设计、行业标准、客户问答沉淀为可检索的知识资产。</p>
        </field>
    </record>


    <record id="action_diecut_kb_compile_workspace" model="ir.actions.act_window">
        <field name="name">Wiki 文章</field>
        <field name="res_model">diecut.kb.article</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_diecut_kb_article_search"/>
        <field name="domain">[('compile_source', '!=', 'manual')]</field>
        <field name="context">{'search_default_ai_compiled': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">这里集中查看 LLM 编译后的 Wiki 文章</p>
            <p>知识管理模块负责把原始资料和结构化产品编译成可审核、可发布、可同步到 Dify 的 Wiki 知识。</p>
        </field>
    </record>

</odoo>
