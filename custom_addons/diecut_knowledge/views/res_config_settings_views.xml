<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_config_settings_diecut_kb" model="ir.ui.view">
        <field name="name">res.config.settings.diecut_knowledge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="行业知识库" string="行业知识库" name="diecut_knowledge" groups="base.group_system">
                    <block title="Dify 知识库 API" name="diecut_kb_dify">
                        <setting id="diecut_kb_dify_base_url" string="Dify API 地址">
                            <field name="diecut_kb_dify_base_url" placeholder="http://dify.local:5001"/>
                        </setting>
                        <setting id="diecut_kb_dify_api_key" string="Dataset API Key">
                            <field name="diecut_kb_dify_api_key" password="True" placeholder="dataset-xxxxxxxx"/>
                        </setting>
                        <setting id="diecut_kb_dify_timeout" string="请求超时(秒)">
                            <field name="diecut_kb_dify_timeout"/>
                        </setting>
                        <setting id="diecut_kb_dify_retries" string="重试次数">
                            <field name="diecut_kb_dify_retries"/>
                        </setting>
                        <setting id="diecut_kb_dify_batch_limit" string="单次定时同步上限">
                            <field name="diecut_kb_dify_batch_limit"/>
                        </setting>
                        <setting id="diecut_kb_attachment_batch_limit" string="附件解析单次上限">
                            <field name="diecut_kb_attachment_batch_limit"/>
                        </setting>
                    </block>
                    <block title="产品库（catalog.item）→ Dify" name="diecut_kb_dify_products">
                        <setting id="diecut_kb_dify_products_dataset_id" string="产品库 Dataset ID">
                            <field name="diecut_kb_dify_products_dataset_id" placeholder="产品库专用 Dataset 的 UUID"/>
                        </setting>
                        <setting id="diecut_kb_dify_products_min_status" string="同步阈值">
                            <field name="diecut_kb_dify_products_min_status"/>
                        </setting>
                        <setting id="diecut_kb_dify_products_batch_limit" string="单次定时同步上限">
                            <field name="diecut_kb_dify_products_batch_limit"/>
                        </setting>
                        <setting id="diecut_kb_dify_test_connection" string="测试连接">
                            <button name="action_test_dify_connection" type="object" string="测试连接" class="btn-primary"/>
                        </setting>
                    </block>
                    <block title="Dify Chat App" name="diecut_kb_dify_chat">
                        <setting id="diecut_kb_dify_chat_app_url" string="Chat App API 地址">
                            <field name="diecut_kb_dify_chat_app_url" placeholder="http://dify.local:5001"/>
                        </setting>
                        <setting id="diecut_kb_dify_chat_api_key" string="Chat App API Key">
                            <field name="diecut_kb_dify_chat_api_key" password="True" placeholder="app-xxxxxxxx"/>
                        </setting>
                    </block>
                    <block title="AI 后端选择" name="diecut_kb_ai_backend_block">
                        <setting id="diecut_kb_ai_backend" string="AI 后端">
                            <field name="diecut_kb_ai_backend"/>
                        </setting>
                    </block>
                    <block title="Claude API" name="diecut_kb_claude">
                        <setting id="diecut_kb_claude_api_key" string="API Key">
                            <field name="diecut_kb_claude_api_key" password="True" placeholder="sk-ant-xxxxxxxx"/>
                        </setting>
                        <setting id="diecut_kb_claude_model" string="模型">
                            <field name="diecut_kb_claude_model"/>
                        </setting>
                        <setting id="diecut_kb_claude_max_tokens" string="最大输出 Token">
                            <field name="diecut_kb_claude_max_tokens"/>
                        </setting>
                        <setting id="diecut_kb_claude_base_url" string="代理地址">
                            <field name="diecut_kb_claude_base_url" placeholder="https://api.example.com"/>
                            <div class="text-muted">可选，通过代理访问时填写。留空则直连 api.anthropic.com。</div>
                        </setting>
                    </block>
                    <block title="AI 编译层" name="diecut_kb_compile">
                        <setting id="diecut_kb_compile_batch_limit" string="单次编译上限">
                            <field name="diecut_kb_compile_batch_limit"/>
                        </setting>
                        <setting id="diecut_kb_compile_auto_publish" string="编译后自动发布">
                            <field name="diecut_kb_compile_auto_publish"/>
                            <div class="text-muted">开启后，编译文章将直接发布并进入现有 Dify 同步链路。</div>
                        </setting>
                    </block>
                    <block title="知识治理" name="diecut_kb_lint">
                        <setting id="diecut_kb_lint_batch_limit" string="单次治理检查上限">
                            <field name="diecut_kb_lint_batch_limit"/>
                        </setting>
                    </block>
                    <block title="Knowledge Vault 文件夹镜像" name="diecut_kb_vault">
                        <setting id="diecut_kb_vault_root_path" string="Vault 根目录">
                            <field name="diecut_kb_vault_root_path" placeholder="/mnt/extra-addons/.diecut_knowledge_vault"/>
                            <div class="text-muted">用于 raw/inbox 与 wiki Markdown 镜像。Odoo 在 Docker 中运行时请填写容器路径，例如 /mnt/extra-addons/.diecut_knowledge_vault；不要直接填写 Windows 的 E:\ 路径。</div>
                        </setting>
                        <setting id="diecut_kb_vault_raw_batch_limit" string="Raw Inbox 扫描上限">
                            <field name="diecut_kb_vault_raw_batch_limit"/>
                        </setting>
                        <setting id="diecut_kb_vault_scan_scope" string="Vault 扫描范围">
                            <field name="diecut_kb_vault_scan_scope"/>
                            <div class="text-muted">默认扫描 raw/inbox、raw/processed 和 raw 下的 Obsidian 原始资料目录。</div>
                        </setting>
                        <setting id="diecut_kb_vault_raw_cron" string="Raw Inbox 定时扫描">
                            <field name="diecut_kb_vault_raw_cron_active" readonly="1"/>
                            <div class="text-muted">定时任务每 30 分钟扫描一次 raw/inbox。建议流程稳定后再启用。</div>
                            <button name="action_enable_raw_inbox_cron"
                                    type="object"
                                    string="启用定时扫描"
                                    class="btn-primary me-2"
                                    invisible="diecut_kb_vault_raw_cron_active"/>
                            <button name="action_disable_raw_inbox_cron"
                                    type="object"
                                    string="停用定时扫描"
                                    class="btn-secondary"
                                    invisible="not diecut_kb_vault_raw_cron_active"/>
                        </setting>
                        <setting id="diecut_kb_vault_actions" string="Vault 操作">
                            <button name="action_init_knowledge_vault" type="object" string="初始化目录" class="btn-secondary me-2"/>
                            <button name="action_export_knowledge_graph" type="object" string="导出 Knowledge Graph" class="btn-secondary"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_diecut_kb_settings" model="ir.actions.act_window">
        <field name="name">行业知识库设置</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'diecut_knowledge'}</field>
    </record>

</odoo>
