<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_diecut_kb_lint_log_search" model="ir.ui.view">
        <field name="name">diecut.kb.lint.log.search</field>
        <field name="model">diecut.kb.lint.log</field>
        <field name="arch" type="xml">
            <search string="搜索知识治理日志">
                <field name="summary"/>
                <field name="article_id"/>
                <field name="source_item_id"/>
                <field name="issue_type"/>
                <field name="severity"/>
                <field name="state"/>
                <separator/>
                <filter string="待处理" name="open" domain="[('state','=','open')]"/>
                <filter string="警告/错误" name="sev_warn" domain="[('severity','in',('warning','error'))]"/>
                <filter string="按问题类型分组" name="group_issue" context="{'group_by':'issue_type'}"/>
                <filter string="按严重级别分组" name="group_severity" context="{'group_by':'severity'}"/>
            </search>
        </field>
    </record>

    <record id="view_diecut_kb_lint_log_list" model="ir.ui.view">
        <field name="name">diecut.kb.lint.log.list</field>
        <field name="model">diecut.kb.lint.log</field>
        <field name="arch" type="xml">
            <list string="知识治理日志">
                <field name="detected_at"/>
                <field name="severity" widget="badge"
                       decoration-info="severity == 'info'"
                       decoration-warning="severity == 'warning'"
                       decoration-danger="severity == 'error'"/>
                <field name="issue_type"/>
                <field name="summary"/>
                <field name="article_id"/>
                <field name="source_item_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_kb_lint_log_form" model="ir.ui.view">
        <field name="name">diecut.kb.lint.log.form</field>
        <field name="model">diecut.kb.lint.log</field>
        <field name="arch" type="xml">
            <form string="知识治理日志">
                <sheet>
                    <group>
                        <group>
                            <field name="severity"/>
                            <field name="issue_type"/>
                            <field name="state"/>
                            <field name="detected_at"/>
                        </group>
                        <group>
                            <field name="article_id"/>
                            <field name="source_item_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="summary"/>
                        <field name="details"/>
                        <field name="suggestion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_diecut_kb_lint_log" model="ir.actions.act_window">
        <field name="name">知识治理日志</field>
        <field name="res_model">diecut.kb.lint.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_diecut_kb_lint_log_search"/>
    </record>

</odoo>
