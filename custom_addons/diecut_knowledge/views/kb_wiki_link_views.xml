<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_diecut_kb_wiki_link_search" model="ir.ui.view">
        <field name="name">diecut.kb.wiki.link.search</field>
        <field name="model">diecut.kb.wiki.link</field>
        <field name="arch" type="xml">
            <search string="搜索 Wiki 图谱关联">
                <field name="source_article_id"/>
                <field name="target_article_id"/>
                <field name="link_type"/>
                <field name="anchor_text"/>
                <field name="reason"/>
                <filter string="冲突" name="contradicts" domain="[('link_type','=','contradicts')]"/>
                <filter string="更新旧结论" name="updates" domain="[('link_type','=','updates')]"/>
                <separator/>
                <filter string="按类型分组" name="group_type" context="{'group_by':'link_type'}"/>
                <filter string="按来源页面分组" name="group_source" context="{'group_by':'source_article_id'}"/>
                <filter string="按目标页面分组" name="group_target" context="{'group_by':'target_article_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_diecut_kb_wiki_link_list" model="ir.ui.view">
        <field name="name">diecut.kb.wiki.link.list</field>
        <field name="model">diecut.kb.wiki.link</field>
        <field name="arch" type="xml">
            <list string="Wiki 图谱关联" create="0" multi_edit="1">
                <field name="source_article_id"/>
                <field name="link_type" widget="badge"
                       decoration-danger="link_type == 'contradicts'"
                       decoration-info="link_type in ('mentions','depends_on')"
                       decoration-success="link_type in ('same_brand','same_material','same_application','same_process')"
                       decoration-warning="link_type in ('updates','compares_with')"/>
                <field name="target_article_id"/>
                <field name="anchor_text"/>
                <field name="confidence"/>
                <field name="reason"/>
                <field name="source_document_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_kb_wiki_link_form" model="ir.ui.view">
        <field name="name">diecut.kb.wiki.link.form</field>
        <field name="model">diecut.kb.wiki.link</field>
        <field name="arch" type="xml">
            <form string="Wiki 图谱关联">
                <sheet>
                    <group>
                        <group>
                            <field name="source_article_id"/>
                            <field name="target_article_id"/>
                            <field name="link_type"/>
                            <field name="anchor_text"/>
                            <field name="confidence"/>
                        </group>
                        <group>
                            <field name="source_document_id"/>
                            <field name="created_by_compile_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="关联原因">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_diecut_kb_wiki_links" model="ir.actions.act_window">
        <field name="name">Wiki 图谱关联</field>
        <field name="res_model">diecut.kb.wiki.link</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_diecut_kb_wiki_link_search"/>
    </record>

</odoo>
