<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="diecut_knowledge.KbWorkspace">
        <div class="o_kb_workspace">
            <div class="o_kb_workspace_sidebar">
                <div class="o_kb_sidebar_header">
                    <h3>知识库</h3>
                    <input
                        type="text"
                        class="form-control form-control-sm"
                        placeholder="搜索页面"
                        t-att-value="state.searchText"
                        t-on-input="onSearchInput"
                    />
                    <div class="o_kb_new_page_row">
                        <input
                            type="text"
                            class="form-control form-control-sm"
                            placeholder="新页面标题"
                            t-att-value="state.newPageTitle"
                            t-on-input="onNewPageInput"
                            t-on-keydown="(ev) => ev.key === 'Enter' ? createPage() : null"
                        />
                        <button type="button" class="btn btn-primary btn-sm" t-on-click="createPage">新增</button>
                    </div>
                </div>
                <PageTree pages="state.pages" selectedId="state.selectedId" onSelect.bind="selectPage" searchText="state.searchText"/>
                <div class="o_kb_sidebar_footer">
                    <button type="button" class="o_kb_recycle_btn" t-on-click="openRecycleBin">垃圾回收站</button>
                </div>
            </div>

            <div class="o_kb_workspace_main">
                <div class="o_kb_workspace_topbar">
                    <div class="o_kb_topbar_path_wrap">
                        <t t-if="selectedBreadcrumbs.length">
                            <t t-foreach="selectedBreadcrumbs" t-as="crumb" t-key="crumb_index">
                                <span class="o_kb_topbar_path" t-esc="crumb"/>
                                <span t-if="!crumb_last" class="o_kb_topbar_sep">/</span>
                            </t>
                        </t>
                        <span t-else="" class="o_kb_topbar_path">未选择页面</span>
                        <span class="o_kb_topbar_status_host" t-ref="statusHost"/>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm o_kb_topbar_delete" t-on-click="archiveCurrentPage" t-att-disabled="!state.selectedId">删除页面</button>
                </div>

                <t t-if="state.selectedId">
                    <div class="o_kb_workspace_editor_shell" t-ref="editorShell">
                        <View t-key="state.selectedId" t-props="formViewProps"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="o_kb_workspace_empty">请先在左侧选择一个页面。</div>
                </t>
            </div>

            <aside class="o_kb_toc_panel">
                <div class="o_kb_toc_head">目录索引</div>
                <div class="o_kb_toc_select_wrap" t-if="state.tocItems.length">
                    <select class="o_kb_toc_select" t-on-change="onTocSelectChange">
                        <option value="">跳转到标题...</option>
                        <t t-foreach="state.tocItems" t-as="item" t-key="`opt_${item.id}`">
                            <option t-att-value="item.id">
                                <t t-out="' '.repeat((item.level - 1) * 2)"/><t t-esc="item.text"/>
                            </option>
                        </t>
                    </select>
                </div>
                <div class="o_kb_toc_list" t-if="state.tocItems.length">
                    <t t-foreach="state.tocItems" t-as="item" t-key="item.id">
                        <button
                            type="button"
                            class="o_kb_toc_item"
                            t-att-style="`padding-left:${(item.level - 1) * 12 + 8}px`"
                            t-att-data-heading-id="item.id"
                            t-on-click="onTocClick"
                            t-esc="item.text"
                        />
                    </t>
                </div>
                <div class="o_kb_toc_empty" t-else="">暂无 H1-H4 标题</div>
            </aside>
        </div>
    </t>
</templates>
