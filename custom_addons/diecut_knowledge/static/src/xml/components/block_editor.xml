<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="diecut_knowledge.BlockEditor">
        <div class="o_kb_editor" t-on-click="closeSlash">
            <div class="o_kb_editor_header">
                <h2 t-if="props.article" t-esc="props.article.name"/>
                <button type="button" class="btn btn-outline-secondary btn-sm" t-on-click="addFirstBlock">新增块</button>
            </div>
            <div class="o_kb_rich_toolbar" t-on-click.stop="() => null">
                <button type="button" class="o_kb_tb_btn" title="加粗" t-on-click="() => format('bold')"><b>B</b></button>
                <button type="button" class="o_kb_tb_btn" title="斜体" t-on-click="() => format('italic')"><i>I</i></button>
                <button type="button" class="o_kb_tb_btn" title="下划线" t-on-click="() => format('underline')"><u>U</u></button>
                <button type="button" class="o_kb_tb_btn" title="一级标题" t-on-click="() => format('formatBlock', 'h1')">H1</button>
                <button type="button" class="o_kb_tb_btn" title="二级标题" t-on-click="() => format('formatBlock', 'h2')">H2</button>
                <button type="button" class="o_kb_tb_btn" title="正文" t-on-click="() => format('formatBlock', 'p')">P</button>
                <select class="o_kb_tb_select" t-att-value="state.fontName" t-on-change="onFontChange">
                    <option value="Arial">Arial</option>
                    <option value="Microsoft YaHei">微软雅黑</option>
                    <option value="SimSun">宋体</option>
                    <option value="Consolas">Consolas</option>
                </select>
            </div>
            <div class="o_kb_editor_hint">快捷键：<code>/</code> 选择块类型，<code>Enter</code> 换行，<code>Ctrl+Enter</code> 新增块，<code>Tab</code>/<code>Shift+Tab</code> 缩进。</div>

            <SlashMenu visible="state.slashVisible" onSelect.bind="applySlash"/>

            <div t-if="props.blocks.length" class="o_kb_block_list">
                <t t-foreach="props.blocks" t-as="block" t-key="block.id">
                    <BlockNode
                        block="block"
                        onUpdate.bind="updateBlock"
                        onDelete.bind="deleteBlock"
                        onInsertAfter.bind="insertAfter"
                        onSlash.bind="showSlash"
                        onOpenCommands.bind="openCommands"
                        onIndent.bind="indentBlock"
                        onOutdent.bind="outdentBlock"
                        onDragStart.bind="dragStart"
                        onDropOn.bind="dropOn"
                        onFocusBlock.bind="setFocusedBlock"
                    />
                </t>
            </div>
            <div t-else="" class="o_kb_editor_empty">当前页面暂无内容块，点击“新增块”开始编辑。</div>
        </div>
    </t>

    <t t-name="diecut_knowledge.BlockNode">
        <div
            class="o_kb_block_node"
            t-att-style="`margin-left:${(props.block.depth || 0) * 18}px`"
            draggable="true"
            t-on-dragstart="onDragStart"
            t-on-dragover="(ev) => ev.preventDefault()"
            t-on-drop="onDrop"
        >
            <div class="o_kb_block_handle_col">
                <button type="button" class="o_kb_handle_btn" title="在后方新增" t-on-click="() => props.onInsertAfter(props.block.id)">+</button>
                <span class="o_kb_drag_handle" title="拖拽排序">⋮⋮</span>
            </div>
            <div class="o_kb_block_body">
                <t t-if="props.block.block_type === 'divider'">
                    <hr/>
                </t>
                <t t-else="">
                    <div
                        t-att-class="textClass"
                        contenteditable="true"
                        t-on-input="onTextChanged"
                        t-on-keydown="onKeydown"
                        t-on-focus="onFocusEditor"
                        t-on-click.stop="() => null"
                        t-att-data-placeholder="placeholder"
                        t-out="contentHtml"
                    />
                </t>
            </div>
            <button type="button" class="o_kb_command_btn" title="块类型" t-on-click="onOpenCommands">/</button>
            <button type="button" class="o_kb_delete_btn" title="删除块" t-on-click="() => props.onDelete(props.block.id)">×</button>
        </div>
    </t>
</templates>
