<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="diecut_knowledge.SlashMenu">
        <div class="o_kb_slash_menu" t-if="props.visible">
            <input
                type="text"
                class="form-control form-control-sm o_kb_slash_search"
                placeholder="搜索块类型..."
                t-att-value="state.query"
                t-on-input="onQueryInput"
            />
            <div class="o_kb_slash_items">
                <t t-foreach="commands" t-as="cmd" t-key="cmd.type">
                    <button class="o_kb_slash_item" type="button" t-on-click="() => selectCommand(cmd)">
                        <span t-esc="cmd.label"/>
                    </button>
                </t>
            </div>
        </div>
    </t>
</templates>
