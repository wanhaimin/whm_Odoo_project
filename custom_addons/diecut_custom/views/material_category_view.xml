<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 材料分类列表视图 -->
    <record id="view_material_category_tree" model="ir.ui.view">
        <field name="name">material.category.list</field>
        <field name="model">material.category</field>
        <field name="arch" type="xml">
            <list string="材料分类">
                <field name="complete_name"/>
                <field name="material_count"/>
            </list>
        </field>
    </record>

    <!-- 材料分类表单视图 -->
    <record id="view_material_category_form" model="ir.ui.view">
        <field name="name">material.category.form</field>
        <field name="model">material.category</field>
        <field name="arch" type="xml">
            <form string="材料分类">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="material_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="描述" name="desc">
                            <field name="description" placeholder="分类描述..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 材料分类动作 -->
    <record id="action_material_category" model="ir.actions.act_window">
        <field name="name">材料分类(模切)</field>
        <field name="res_model">material.category</field>
        <field name="view_mode">list,form</field>
        <field name="path">material-categories-diecut</field>
    </record>
</odoo>

