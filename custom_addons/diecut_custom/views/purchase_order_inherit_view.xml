<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 在采购订单中只显示供应商 -->
    <record id="view_purchase_order_form_supplier_filter" model="ir.ui.view">
        <field name="name">purchase.order.form.supplier.filter</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <!-- 只显示标记为"供应商"或"客户和供应商"的公司 -->
                <attribute name="domain">[('is_company', '=', True), ('partner_type', 'in', ['supplier', 'both'])]</attribute>
                <attribute name="options">{'no_create': False, 'no_open': False}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
