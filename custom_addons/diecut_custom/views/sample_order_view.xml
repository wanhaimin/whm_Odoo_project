<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 打样订单列表视图 -->
    <record id="view_sample_order_list_custom" model="ir.ui.view">
        <field name="name">sample.order.list.custom</field>
        <field name="model">sample.order</field>
        <field name="arch" type="xml">
            <list string="打样订单">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_name"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- 打样订单表单视图 -->
    <record id="view_sample_order_form_custom" model="ir.ui.view">
        <field name="name">sample.order.form.custom</field>
        <field name="model">sample.order</field>
        <field name="arch" type="xml">
            <form string="打样订单">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="product_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 打样订单动作 -->
    <record id="action_sample_order_custom" model="ir.actions.act_window">
        <field name="name">打样订单</field>
        <field name="res_model">sample.order</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

