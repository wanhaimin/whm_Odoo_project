<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 继承材料清单表单，添加网站发布功能 -->
    <record id="view_my_material_form_inherit" model="ir.ui.view">
        <field name="name">my.material.form.inherit</field>
        <field name="model">my.material</field>
        <field name="inherit_id" ref="my_material_list.view_my_material_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_publish" string="发布到网站" type="object" invisible="is_published" class="oe_highlight"/>
                    <button name="action_unpublish" string="从网站取消" type="object" invisible="not is_published"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='unit_price']" position="after">
                <field name="is_published" widget="boolean_toggle" string="官网发布"/>
                <field name="website_url" readonly="1" invisible="not is_published"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="网站内容">
                    <group>
                        <field name="application" placeholder="例如：电子产品绝缘、汽车内饰等..."/>
                        <field name="process_note" placeholder="例如：建议模切速度不超过..."/>
                    </group>
                    <group string="互动统计">
                        <group>
                            <field name="view_count"/>
                            <field name="inquiry_count"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- 继承材料清单列表视图 -->
    <record id="view_my_material_list_inherit" model="ir.ui.view">
        <field name="name">my.material.list.inherit</field>
        <field name="model">my.material</field>
        <field name="inherit_id" ref="my_material_list.view_my_material_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_published" string="官网发布" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>


    <!-- 继承搜索视图 -->
    <record id="view_my_material_search_inherit" model="ir.ui.view">
        <field name="name">my.material.search.inherit</field>
        <field name="model">my.material</field>
        <field name="inherit_id" ref="my_material_list.view_my_material_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='group_by_category']" position="before">
                <filter string="网站已发布" name="published" domain="[('is_published', '=', True)]"/>
                <separator/>
            </xpath>
        </field>
    </record>
</odoo>
