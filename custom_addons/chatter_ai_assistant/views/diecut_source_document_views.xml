<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_diecut_catalog_source_document_form_import_tracking" model="ir.ui.view">
        <field name="name">diecut.catalog.source.document.form.import.tracking</field>
        <field name="model">diecut.catalog.source.document</field>
        <field name="inherit_id" ref="diecut.view_diecut_catalog_source_document_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_identify_handbook_structure"
                    string="识别手册结构"
                    type="object"
                    class="btn btn-secondary"
                />
                <button
                    name="action_open_handbook_review"
                    string="打开系列总览"
                    type="object"
                    class="btn btn-secondary o_open_handbook_review_tab_button"
                    invisible="not handbook_review_id"
                />
            </xpath>
            <xpath expr="//field[@name='parse_version']" position="after">
                <field name="matched_catalog_item_id" readonly="1"/>
                <field name="chatter_ai_external_document_type" readonly="1"/>
                <field name="chatter_ai_external_source_platform" readonly="1"/>
                <field name="chatter_ai_trace_id" readonly="1"/>
                <field name="handbook_review_id" readonly="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="系列总览" invisible="not handbook_review_id">
                    <group>
                        <group>
                            <field name="handbook_review_family_name" readonly="1"/>
                            <field name="handbook_review_confidence" readonly="1"/>
                            <field name="handbook_review_series_count" readonly="1"/>
                            <field name="handbook_review_model_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="handbook_review_param_total" readonly="1"/>
                            <field name="handbook_review_reused_param_count" readonly="1"/>
                            <field name="handbook_review_pending_param_count" readonly="1"/>
                            <field name="handbook_review_issue_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="handbook_review_summary" nolabel="1" readonly="1"/>
                        <field name="handbook_review_document_outline" nolabel="1" readonly="1"/>
                    </group>
                    <field name="handbook_review_series_ids" nolabel="1" readonly="1">
                        <list default_order="sequence, id" create="0" edit="0" delete="0">
                            <field name="series_long_name"/>
                            <field name="page_range"/>
                            <field name="model_count"/>
                            <field name="param_total"/>
                            <field name="reused_param_count"/>
                            <field name="pending_param_count"/>
                            <field name="issue_count"/>
                            <field name="confidence"/>
                        </list>
                    </field>
                </page>
            </xpath>
            <xpath expr="//page[field[@name='handbook_review_series_ids']]" position="attributes">
                <attribute name="name">handbook_review_tab</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_diecut_catalog_source_document_form_chatter_ai_banner" model="ir.ui.view">
        <field name="name">diecut.catalog.source.document.form.chatter.ai.banner</field>
        <field name="model">diecut.catalog.source.document</field>
        <field name="inherit_id" ref="diecut.view_diecut_catalog_source_document_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[1]" position="before">
                <group col="1" invisible="not chatter_ai_status_banner_html">
                    <field name="chatter_ai_status_banner_html" nolabel="1" readonly="1" widget="html"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
