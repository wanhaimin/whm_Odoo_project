<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 材料列表视图 -->
    <record id="view_material_list_custom" model="ir.ui.view">
        <field name="name">material.material.list.custom</field>
        <field name="model">material.material</field>
        <field name="arch" type="xml">
            <list string="材料">
                <field name="code" />
                <field name="name" />
                <field name="category_id" />
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'development'" />
            </list>
        </field>
    </record>
    <!-- 材料表单视图 -->
    <record id="view_material_form_custom" model="ir.ui.view">
        <field name="name">material.material.form.custom</field>
        <field name="model">material.material</field>
        <field name="arch" type="xml">
            <form string="材料">
                <header>
                    <button name="action_publish" string="发布到网站" type="object" invisible="is_published" class="oe_highlight" />
                    <button name="action_unpublish" string="从网站取消" type="object" invisible="not is_published" />
                    <field name="state" widget="statusbar" statusbar_visible="active,development,discontinued" />
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_increase_view_count" type="object" class="oe_stat_button" icon="fa-eye">
                            <field name="view_count" string="浏览" widget="statinfo" />
                        </button>
                        <button name="action_increase_inquiry_count" type="object" class="oe_stat_button" icon="fa-envelope-o">
                            <field name="inquiry_count" string="询价" widget="statinfo" />
                        </button>
                        <field name="is_published" widget="website_redirect_button" />
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}" />
                    <div class="oe_title">
                        <label string="材料名称" for="name" />
                        <h1>
                            <field name="name" placeholder="例如：3M 双面胶" />
                        </h1>
                        <label string="编号" for="code" />
                        <h3>
                            <field name="code" />
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" />
                            <field name="manufacturer_id" />
                            <field name="brand" />
                            <field name="origin" />
                        </group>
                        <group>
                            <field name="website_url" invisible="1" />
                        </group>
                    </group>
                    <notebook>
                        <page name="physical" string="物理特性">
                            <group>
                                <group string="尺寸与外观">
                                    <field name="thickness" />
                                    <field name="width" />
                                    <field name="length" />
                                    <field name="density" />
                                    <field name="color" />
                                    <field name="transparency" />
                                </group>
                                <group string="性能指标">
                                    <field name="tensile_strength" />
                                    <field name="tear_strength" />
                                    <label string="耐温范围" for="temp_resistance_min" />
                                    <div class="o_row">
                                        <field name="temp_resistance_min" />
                                        <span>~</span>
                                        <field name="temp_resistance_max" />
                                    </div>
                                    <field name="adhesion" />
                                </group>
                            </group>
                        </page>
                        <page name="commercial" string="商务信息">
                            <group>
                                <group>
                                    <field name="reference_price" />
                                    <field name="currency_id" invisible="1" />
                                    <field name="moq" />
                                    <field name="moq_unit" />
                                    <field name="lead_time" />
                                </group>
                                <group string="供应商">
                                    <field name="supplier_ids" widget="many2many_tags" />
                                </group>
                            </group>
                        </page>
                        <page name="documents" string="文档资料">
                            <group>
                                <field name="datasheet" filename="datasheet_filename" />
                                <field name="datasheet_filename" invisible="1" />
                                <field name="test_report" filename="test_report_filename" />
                                <field name="test_report_filename" invisible="1" />
                            </group>
                        </page>
                        <page name="application" string="应用信息">
                            <group>
                                <field name="application" />
                                <field name="process_note" />
                                <field name="caution" />
                            </group>
                        </page>
                        <page name="description" string="详细描述">
                            <field name="description" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <!-- 材料动作 -->
    <record id="action_material_custom" model="ir.actions.act_window">
        <field name="name">原材料库</field>
        <field name="res_model">material.material</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>