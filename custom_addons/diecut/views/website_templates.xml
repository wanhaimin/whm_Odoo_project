<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 材料列表页面 -->
    <template id="materials_list" name="Materials List">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <!-- 头部 Banner -->
                <section class="s_banner bg-primary py-5 text-white">
                    <div class="container text-center">
                        <h1 class="display-4 font-weight-bold">精选材料库</h1>
                        <p class="lead">探索我们为您精心挑选的高质量模切与加工材料</p>
                    </div>
                </section>

                <div class="container mt-5">
                    <div class="row">
                        <!-- 侧边栏 - 精美的分类导航 -->
                        <div class="col-lg-3">
                            <div class="card border-0 shadow-sm mb-4">
                                <div class="card-header bg-white border-bottom-0 pb-0">
                                    <h5 class="mb-0 text-primary"><i class="fa fa-filter mr-2"></i>材料分类</h5>
                                </div>
                                <div class="card-body">
                                    <div class="list-group list-group-flush">
                                        <a href="/materials" class="list-group-item list-group-item-action border-0 rounded mb-1 px-3 d-flex justify-content-between align-items-center" t-att-class="'active text-white' if not current_category else ''">
                                            <span><i class="fa fa-th-large mr-2"></i>全部材料</span>
                                        </a>
                                        <t t-foreach="categories" t-as="category">
                                            <a t-att-href="'/materials?category=%s' % category.id" 
                                               class="list-group-item list-group-item-action border-0 rounded mb-1 px-3 d-flex justify-content-between align-items-center"
                                               t-att-class="'active text-white' if current_category == category.id else ''">
                                                <span><t t-esc="category.name"/></span>
                                                <span class="badge badge-pill" t-att-class="'badge-light text-primary' if current_category == category.id else 'badge-primary-soft text-primary'">
                                                    <t t-esc="category.material_count"/>
                                                </span>
                                            </a>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- 搜索框 -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-3">
                                    <form action="/materials" method="get">
                                        <div class="input-group">
                                            <input type="text" name="search" class="form-control border-right-0" placeholder="搜索材料..." t-att-value="search or ''"/>
                                            <div class="input-group-append">
                                                <button type="submit" class="btn btn-primary border-left-0">
                                                    <i class="fa fa-search"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        
                        <!-- 主内容区 -->
                        <div class="col-lg-9">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h3 class="font-weight-bold mb-0">
                                    <t t-if="current_category">
                                        <t t-esc="categories.filtered(lambda c: c.id == current_category).name"/>
                                    </t>
                                    <t t-else="">所有材料</t>
                                </h3>
                                <div class="text-muted small">
                                    共找到 <t t-esc="total_count"/> 种材料
                                </div>
                            </div>
                            
                            <!-- 材料卡片 -->
                            <div class="row">
                                <t t-foreach="materials" t-as="material">
                                    <div class="col-md-4 mb-4">
                                        <div class="card h-100 border-0 shadow-sm material-card transition-hover">
                                            <a t-att-href="'/material/%s' % material.id" class="text-decoration-none text-dark">
                                                <div class="o_card_image_box overflow-hidden" style="height: 180px;">
                                                    <t t-if="material.image_1920">
                                                        <img t-att-src="'/web/image/product.template/%s/image_1920' % material.id" 
                                                             class="card-img-top h-100 object-fit-cover scale-hover" alt="Material Image"/>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center h-100">
                                                            <i class="fa fa-image fa-3x text-muted opacity-50"></i>
                                                        </div>
                                                    </t>
                                                </div>
                                                <div class="card-body p-3">
                                                    <div class="badge badge-primary-soft text-primary mb-2">
                                                        <t t-esc="material.categ_id.name"/>
                                                    </div>
                                                    <h5 class="card-title font-weight-bold mb-1 text-truncate" t-att-title="material.name">
                                                        <t t-esc="material.name"/>
                                                    </h5>
                                                    <div class="text-muted small mb-3">
                                                        <i class="fa fa-barcode mr-1"></i> <t t-esc="material.default_code"/>
                                                    </div>
                                                    <div class="d-flex justify-content-between align-items-end">
                                                        <div class="price_box">
                                                            <div class="text-primary font-weight-bold h5 mb-0">
                                                                ¥<t t-esc="'%.2f' % (material.list_price or 0.0)"/>
                                                            </div>
                                                            <div class="text-muted extra-small">参考价 / m²</div>
                                                        </div>
                                                        <span class="btn btn-outline-primary btn-sm rounded-pill px-3">详情</span>
                                                    </div>
                                                </div>
                                            </a>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            
                            <!-- 分页 -->
                            <div class="d-flex justify-content-center mt-4">
                                <t t-call="website.pager"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 自定义 CSS 提升美感 -->
            <style>
                .material-card {
                    transition: all 0.3s ease;
                    border-radius: 12px;
                }
                .material-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
                }
                .object-fit-cover {
                    object-fit: cover;
                }
                .scale-hover {
                    transition: transform 0.5s ease;
                }
                .material-card:hover .scale-hover {
                    transform: scale(1.1);
                }
                .badge-primary-soft {
                    background-color: rgba(0, 123, 255, 0.1);
                }
                .extra-small {
                    font-size: 0.75rem;
                }
                .transition-hover {
                    transition: transform 0.2s;
                }
                .list-group-item.active {
                    background-color: var(--primary);
                    border-color: var(--primary);
                }
            </style>
        </t>
    </template>

    <!-- 材料详情页面 -->
    <template id="material_detail" name="Material Detail">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-5">
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb bg-transparent p-0">
                            <li class="breadcrumb-item"><a href="/materials">材料库</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><t t-esc="material.name"/></li>
                        </ol>
                    </nav>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="card border-0 shadow-sm overflow-hidden rounded-lg">
                                <t t-if="material.image_1920">
                                    <img t-att-src="'/web/image/product.template/%s/image_1920' % material.id" 
                                         class="img-fluid w-100" alt="Material Image"/>
                                </t>
                                <t t-else="">
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 500px;">
                                        <i class="fa fa-image fa-5x text-muted opacity-50"></i>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="col-md-6 pl-md-5">
                            <span class="badge badge-primary-soft text-primary px-3 py-2 mb-3">
                                <t t-esc="material.categ_id.name"/>
                            </span>
                            <h1 class="display-5 font-weight-bold mb-2"><t t-esc="material.name"/></h1>
                            <p class="text-muted lead mb-4">材料编号: <t t-esc="material.default_code"/></p>
                            
                            <div class="d-flex align-items-center mb-4">
                                <div class="price-v2 p-4 bg-light rounded-lg d-inline-block border-left border-primary border-4" style="border-left-width: 4px !important;">
                                    <div class="text-muted small mb-1">参考单价</div>
                                    <div class="h2 mb-0 text-primary font-weight-bold">
                                        ¥<t t-esc="'%.2f' % (material.list_price or 0.0)"/> <small class="text-muted">/ <t t-esc="material.uom_id.name or 'm²'"/></small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row mt-4 no-gutters">
                                <div class="col-6 pr-2 mb-3">
                                    <div class="p-3 bg-white border rounded shadow-sm">
                                        <div class="text-muted extra-small">厚度</div>
                                        <div class="font-weight-bold"><t t-esc="material.thickness or '-'"/> mm</div>
                                    </div>
                                </div>
                                <div class="col-6 pl-2 mb-3">
                                    <div class="p-3 bg-white border rounded shadow-sm">
                                        <div class="text-muted extra-small">宽度</div>
                                        <div class="font-weight-bold"><t t-esc="material.width or '-'"/> mm</div>
                                    </div>
                                </div>
                                <div class="col-6 pr-2">
                                    <div class="p-3 bg-white border rounded shadow-sm">
                                        <div class="text-muted extra-small">长度</div>
                                        <div class="font-weight-bold"><t t-esc="material.length or '-'"/> M</div>
                                    </div>
                                </div>
                                <div class="col-6 pl-2">
                                    <div class="p-3 bg-white border rounded shadow-sm">
                                        <div class="text-muted extra-small">材质/牌号</div>
                                        <div class="font-weight-bold"><t t-esc="material.material_type or '-'"/></div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-5 d-flex">
                                <a href="/sample/order" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-sm mr-3">
                                    <i class="fa fa-flask mr-2"></i>预约打样
                                </a>
                                <button class="btn btn-outline-secondary btn-lg px-4 py-3 rounded-pill" 
                                        data-toggle="modal" data-target="#inquiryModal">
                                    <i class="fa fa-comment-o mr-2"></i>获取报价
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 详情选项卡 -->
                    <div class="row mt-5 pt-4">
                        <div class="col-12">
                            <ul class="nav nav-pills nav-justified mb-4" id="pills-tab" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active rounded-pill mr-2" data-toggle="pill" href="#p-description">详细描述</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link rounded-pill mr-2" data-toggle="pill" href="#p-specs">技术参数</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link rounded-pill" data-toggle="pill" href="#p-application">应用领域</a>
                                </li>
                            </ul>
                            
                            <div class="tab-content card border-0 shadow-sm p-4 rounded-lg">
                                <div id="p-description" class="tab-pane fade show active">
                                    <t t-if="material.description">
                                        <t t-out="material.description"/>
                                    </t>
                                    <t t-else="">
                                        <div class="text-center py-5 text-muted italic">暂无详细描述信息</div>
                                    </t>
                                </div>
                                <div id="p-specs" class="tab-pane fade">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <table class="table borderless">
                                                <tr><th class="border-0">规格型号:</th> <td class="border-0"><t t-esc="material.spec or '-'"/></td></tr>
                                                <tr><th class="border-0">计量单位:</th> <td class="border-0"><t t-esc="material.uom_id.name or '-'"/></td></tr>
                                                <tr><th class="border-0">采购周期:</th> <td class="border-0"><t t-esc="material.lead_time or '-'"/> 天</td></tr>
                                            </table>
                                        </div>
                                        <div class="col-md-6">
                                            <table class="table borderless">
                                                <tr><th class="border-0">颜色:</th> <td class="border-0"><t t-esc="material.color or '-'"/></td></tr>
                                                <tr><th class="border-0">克重:</th> <td class="border-0"><t t-esc="material.weight_gram or '-'"/> g</td></tr>
                                                <tr><th class="border-0">批次管理:</th> <td class="border-0"><t t-esc="'是' if material.track_batch else '否'"/></td></tr>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div id="p-application" class="tab-pane fade">
                                    <div class="mb-4">
                                        <h5 class="font-weight-bold text-primary">典型应用</h5>
                                        <p class="lead"><t t-esc="material.application or '暂无应用说明'"/></p>
                                    </div>
                                    <t t-if="material.process_note">
                                        <h5 class="font-weight-bold text-primary">加工建议</h5>
                                        <p class="bg-light p-3 rounded"><t t-esc="material.process_note"/></p>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 询价弹窗 -->
                <div class="modal fade" id="inquiryModal" tabindex="-1" role="dialog">
                  <div class="modal-dialog" role="document">
                    <div class="modal-content border-0 shadow-lg">
                      <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">获取针对 "<t t-esc="material.name"/>" 的报价</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                          <span aria-hidden="true">&amp;times;</span>
                        </button>
                      </div>
                      <div class="modal-body">
                        <p>请留下您的联系方式，我们的专业工程师将为您提供详细报价和技术建议。</p>
                        <form id="inquiryForm">
                            <div class="form-group">
                                <label>您的需求描述</label>
                                <textarea class="form-control" rows="3" placeholder="例如：月用量、具体尺寸要求等..."></textarea>
                            </div>
                        </form>
                      </div>
                      <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">取消</button>
                        <button type="button" class="btn btn-primary rounded-pill px-4" onclick="alert('询价功能已收到，我们将尽快联系您！')">确认提交</button>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
            
            <style>
                .badge-primary-soft { background: rgba(0, 123, 255, 0.1); }
                .borderless td, .borderless th { border: none !important; }
                .shadow-sm { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important; }
                .shadow-lg { box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important; }
            </style>
        </t>
    </template>

    <!-- 打样订单表单 -->
    <template id="sample_order_form" name="Sample Order Form">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-4">
                    <h2>在线打样</h2>
                    <form action="/sample/order/submit" method="post" class="mt-4">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <h4>产品信息</h4>
                                <div class="form-group">
                                    <label>产品名称 *</label>
                                    <input type="text" name="product_name" class="form-control" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label>产品型号</label>
                                    <input type="text" name="product_model" class="form-control"/>
                                </div>
                                <div class="form-group">
                                    <label>应用场景</label>
                                    <input type="text" name="application" class="form-control"/>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <h4>打样要求</h4>
                                <div class="form-group">
                                    <label>选择材料 *</label>
                                    <select name="material_id" class="form-control" required="required">
                                        <option value="">请选择...</option>
                                        <t t-foreach="materials" t-as="mat">
                                            <option t-att-value="mat.id">
                                                <t t-esc="mat.name"/> (<t t-esc="mat.code"/>)
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label>长度(mm) *</label>
                                        <input type="number" name="length" class="form-control" step="0.01" required="required"/>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>宽度(mm) *</label>
                                        <input type="number" name="width" class="form-control" step="0.01" required="required"/>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <label>厚度(μm)</label>
                                        <input type="number" name="thickness" class="form-control" step="0.01"/>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>打样数量 *</label>
                                    <input type="number" name="quantity" class="form-control" value="10" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label>加工类型 *</label>
                                    <select name="process_type" class="form-control" required="required">
                                        <option value="die_cut">模切</option>
                                        <option value="lamination">贴合</option>
                                        <option value="printing">印刷</option>
                                        <option value="slitting">分切</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>紧急程度 *</label>
                                    <select name="urgency" class="form-control" required="required">
                                        <option value="normal">正常(3-5天)</option>
                                        <option value="urgent">加急(1-2天) +50%</option>
                                        <option value="super_urgent">特急(24小时) +100%</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label>特殊要求</label>
                            <textarea name="special_requirements" class="form-control" rows="3"></textarea>
                        </div>
                        
                        <div class="form-group">
                            <label>备注</label>
                            <textarea name="note" class="form-control" rows="2"></textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary btn-lg">提交打样订单</button>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- 订单成功页面 -->
    <template id="sample_order_success" name="Sample Order Success">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-5">
                    <div class="alert alert-success text-center">
                        <h2>✓ 订单提交成功!</h2>
                        <p class="lead">您的打样订单已成功提交</p>
                    </div>
                    
                    <div class="card">
                        <div class="card-body">
                            <h4>订单信息</h4>
                            <table class="table">
                                <tr>
                                    <th>订单号:</th>
                                    <td><t t-esc="order.name"/></td>
                                </tr>
                                <tr>
                                    <th>产品名称:</th>
                                    <td><t t-esc="order.product_name"/></td>
                                </tr>
                                <tr>
                                    <th>打样数量:</th>
                                    <td><t t-esc="order.quantity"/> 片</td>
                                </tr>
                                <tr>
                                    <th>紧急程度:</th>
                                    <td><t t-esc="dict(order._fields['urgency'].selection).get(order.urgency)"/></td>
                                </tr>
                                <tr>
                                    <th>预估费用:</th>
                                    <td class="text-primary"><strong>¥<t t-esc="'%.2f' % order.total_cost"/></strong></td>
                                </tr>
                            </table>
                            
                            <p class="text-muted">我们会尽快与您联系确认订单详情。</p>
                            
                            <a href="/my/sample/orders" class="btn btn-primary">查看我的订单</a>
                            <a href="/materials" class="btn btn-outline-secondary">继续浏览材料</a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- 我的打样订单 -->
    <template id="my_sample_orders" name="My Sample Orders">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-4">
                    <h2>我的打样订单</h2>
                    
                    <t t-if="orders">
                        <table class="table table-striped mt-4">
                            <thead>
                                <tr>
                                    <th>订单号</th>
                                    <th>产品名称</th>
                                    <th>数量</th>
                                    <th>总费用</th>
                                    <th>状态</th>
                                    <th>创建时间</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="orders" t-as="order">
                                    <tr>
                                        <td><t t-esc="order.name"/></td>
                                        <td><t t-esc="order.product_name"/></td>
                                        <td><t t-esc="order.quantity"/></td>
                                        <td>¥<t t-esc="'%.2f' % order.total_cost"/></td>
                                        <td>
                                            <span t-att-class="'badge badge-%s' % ('success' if order.state == 'delivered' else 'primary')">
                                                <t t-esc="dict(order._fields['state'].selection).get(order.state)"/>
                                            </span>
                                        </td>
                                        <td><t t-esc="order.create_date.strftime('%Y-%m-%d')"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="alert alert-info mt-4">
                            <p>您还没有打样订单</p>
                            <a href="/sample/order" class="btn btn-primary">立即打样</a>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- 添加到网站菜单 -->
    <record id="menu_materials" model="website.menu">
        <field name="name">材料库</field>
        <field name="url">/materials</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">50</field>
    </record>

    <record id="menu_sample_order" model="website.menu">
        <field name="name">在线打样</field>
        <field name="url">/sample/order</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">51</field>
    </record>
</odoo>
