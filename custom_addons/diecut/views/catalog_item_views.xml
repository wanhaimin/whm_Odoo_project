                        <field name="spec_line_ids" nolabel="1" colspan="2">
                            <list editable="bottom" default_order="sequence, id">
                                <field name="sequence" optional="hide"/>
                                <field name="spec_def_id" domain="[('id', 'in', parent.spec_def_domain_ids)]"/>
                                <field name="value_type" readonly="1" optional="hide"/>
                                <field name="value_text" string="值" widget="diecut_spec_value_widget"/>
                                <field name="unit"/>
                                <field name="test_method"/>
                                <field name="test_condition"/>
                                <field name="remark"/>
                                <field name="param_key" column_invisible="True"/>
                                <field name="param_name" column_invisible="True"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_diecut_catalog_item_gray" model="ir.actions.act_window">
        <field name="name">材料型号清单</field>
        <field name="res_model">diecut.catalog.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_diecut_catalog_item_search"/>
        <field name="context" eval="{
                'split_form_view_id': ref('view_diecut_catalog_item_split_form_standalone'),
                'split_form_view_ref': 'diecut.view_diecut_catalog_item_split_form_standalone',
                'split_storage_key': 'action_diecut_catalog_item_gray',
                'edit': True,
                'create': True
            }"/>
        <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_diecut_catalog_item_split_tree_standalone')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_diecut_catalog_item_form')})
            ]"/>
    </record>
</odoo>
