        <field name="view_ids" eval="[                 (5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('view_diecut_catalog_item_split_tree_standalone')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('view_diecut_catalog_item_form')})             ]" />
    </record>

    <record id="view_diecut_catalog_item_form_three_sections" model="ir.ui.view">
        <field name="name">diecut.catalog.item.form.three.sections</field>
        <field name="model">diecut.catalog.item</field>
        <field name="priority">200</field>
        <field name="inherit_id" ref="view_diecut_catalog_item_form" />
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group[.//field[@name='brand_id'] and .//field[@name='code']][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/sheet/group[.//field[@name='special_applications'] and .//field[@name='product_features']][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/sheet/group[.//field[@name='thickness'] and .//field[@name='fire_rating']][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/sheet/group[.//field[@name='spec_line_ids']][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/sheet/div[@name='button_box']" position="after">
                <group string="基础属性" class="o_diecut_primary_section" colspan="2" col="1">
                    <group class="o_diecut_primary_section_body" col="1" colspan="2">
                        <group colspan="2" col="2">
                            <group colspan="2">
                                <field name="brand_id" />
                                <field name="categ_id" />
                                <field name="name" />
                                <field name="code" />
                                <field name="series_id" options="{'no_quick_create': True}" context="{'default_brand_id': brand_id}" />
                                    <field name="catalog_status" />
                                <field name="manufacturer_id" context="{'show_short_name': True}" domain="[('is_company', '=', True)]" />
                                <field name="param_domain_ids" invisible="1" />
                            </group>
                            <group colspan="2" />
                        </group>
                        <group colspan="2" col="2">
                            <group>
                                <field name="thickness" />
                                <field name="thickness_std" />
                                <field name="adhesive_thickness" />
                                <field name="color_id" />
                                <field name="adhesive_type_id" />
                                <field name="base_material_id" />
                                <field name="ref_price" />
                            </group>
                            <group>
                                <field name="is_rohs" />
                                <field name="is_reach" />
                                <field name="is_halogen_free" />
                                <field name="fire_rating" />
                            </group>
                        </group>
                    </group>
                </group>
                <group string="选型信息" class="o_diecut_primary_section" colspan="2" col="1">
                    <group class="o_diecut_primary_section_body o_diecut_selection_section_body" col="1" colspan="2">
                        <group string="系列标签" colspan="2">
                            <group colspan="2" col="1" class="o_diecut_tag_stack">
                                <group col="1" colspan="2">
                                    <field name="series_function_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" readonly="1" />
                                </group>
                                <group col="1" colspan="2">
                                    <field name="series_application_tag_ids" widget="many2many_tags" readonly="1" />
                                </group>
                                <group col="1" colspan="2">
                                    <field name="series_feature_tag_ids" widget="many2many_tags" readonly="1" />
                                </group>
                            </group>
                        </group>
                        <group string="系列参考(只读)" colspan="2">
                            <div class="o_diecut_reference_rows" colspan="2">
                                <div class="o_diecut_reference_row">
                                    <div class="o_form_label o_diecut_reference_label">系列特性</div>
                                    <div class="o_diecut_reference_value">
                                        <field name="product_features" readonly="1" nolabel="1" />
                                    </div>
                                </div>
                                <div class="o_diecut_reference_row">
                                    <div class="o_form_label o_diecut_reference_label">系列描述</div>
                                    <div class="o_diecut_reference_value">
                                        <field name="product_description" readonly="1" nolabel="1" />
                                    </div>
                                </div>
                                <div class="o_diecut_reference_row">
                                    <div class="o_form_label o_diecut_reference_label">系列主要应用</div>
