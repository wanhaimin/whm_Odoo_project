<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. 扩展 Product Form View: 增加“模切信息”页签 -->
    <record id="product_template_form_view_diecut" model="ir.ui.view">
        <field name="name">product.template.form.diecut</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <!-- 在基本信息部分加入 'is_raw_material' 开关 -->
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="is_raw_material" />
                    <label for="is_raw_material" />
                </span>
            </div>

            <!-- 增加一个新的 Notebook Page -->
            <notebook position="inside">
                <page string="模切属性" name="diecut_props" invisible="not is_raw_material">
                    <group>
                        <group string="规格参数">
                            <field name="spec" />
                            <field name="thickness" />
                            <field name="width" />
                            <field name="length" />
                            <field name="rs_type" />
                            <field name="color" />
                            <field name="material_type" />
                        </group>
                        <group string="物理特性">
                            <field name="brand" />
                            <field name="origin" />
                            <field name="density" />
                            <field name="transparency" />
                            <field name="tensile_strength" />
                            <field name="tear_strength" />
                            <field name="temp_resistance_min" />
                            <field name="temp_resistance_max" />
                            <field name="adhesion" />
                        </group>
                    </group>
                    <group>
                        <group string="特有价格">
                            <field name="raw_material_unit_price" widget="monetary" />
                            <field name="price_usd" />
                            <field name="price_hkd" />
                            <field name="price_rmb" />
                            <field name="price_unit" />
                        </group>
                        <group string="采购与供应">
                            <field name="main_vendor_id" />
                            <field name="quote_date" />
                            <field name="lead_time" />
                            <field name="min_order_qty" />
                            <field name="datasheet_filename" invisible="1"/>
                            <field name="datasheet" filename="datasheet_filename"/>
                        </group>
                    </group>
                    <group string="供应商价格表">
                        <field name="seller_ids" context="{'product_template_invisible_variant': True}" nolabel="1">
                            <list editable="bottom">
                                <field name="partner_id" domain="[('supplier_rank', '>', 0)]" context="{'default_supplier_rank': 1, 'res_partner_search_mode': 'supplier'}"/>
                                <field name="min_qty" />
                                <field name="price" string="单价(卷)" optional="show" help="主单位单价"/>
                                <field name="price_per_m2" optional="show"/>
                                <field name="price_per_kg" optional="hide"/>
                                <field name="currency_id" groups="base.group_multi_currency"/>
                                <field name="date_start" optional="hide"/>
                                <field name="date_end" optional="hide"/>
                                <field name="delay" string="交期(天)"/>
                            </list>
                        </field>
                    </group>
                     <group string="应用与备注">
                        <field name="application" />
                        <field name="process_note" />
                        <field name="caution" />
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- 2. 原材料库 专用 Tree View -->
    <record id="view_diecut_raw_material_tree" model="ir.ui.view">
        <field name="name">diecut.raw.material.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="原材料库" multi_edit="1" editable="bottom">
                <field name="name" />
                <field name="default_code" optional="show" />
                <field name="categ_id" />
                <field name="main_vendor_id" optional="show" />
                <field name="thickness" optional="show" />
                <field name="width" optional="show" />
                <field name="color" optional="show" />
                <field name="is_raw_material" invisible="1" />
                <field name="standard_price" optional="hide" />
                <field name="raw_material_unit_price" optional="show" />
                <field name="uom_id" optional="show" />
                <button name="action_open_detail" type="object" string=" " icon="fa-external-link" title="打开详情页" class="btn-secondary"/>
            </list>
        </field>
    </record>

    <!-- 3. 定义动作 Action: 只显示“是原材料”的产品 -->
    <record id="action_diecut_raw_material" model="ir.actions.act_window">
        <field name="name">原材料库</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_raw_material', '=', True)]</field>
        <field name="context">{'default_is_raw_material': True, 'default_purchase_ok': True, 'default_sale_ok': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_diecut_raw_material_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('product.product_template_only_form_view')})]" />
    </record>

    <!-- 4. 菜单 -->
    <!-- 注意：menu_my_material_root 这个父菜单ID需要确保存在， 
         我们在这个文件里定义它，供其他文件引用 -->
    <menuitem id="menu_my_material_root" name="材料管理" sequence="10" />

    <!-- 挂载动作 -->
    <menuitem id="menu_diecut_raw_material_list" 
              name="原材料列表" 
              parent="menu_my_material_root" 
              action="action_diecut_raw_material" 
              sequence="10" />

</odoo>