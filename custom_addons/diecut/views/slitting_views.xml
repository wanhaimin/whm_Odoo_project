<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for Slitting Order -->
    <record id="seq_material_slitting" model="ir.sequence">
        <field name="name">Material Slitting Order</field>
        <field name="code">my.material.slitting</field>
        <field name="prefix">SLIT/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False" />
    </record>
    <!-- Stock Lot Extension View -->
    <record id="view_production_lot_form_inherit_material" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit.material</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="material_width" />
                <field name="material_length" />
                <field name="parent_lot_id" readonly="1" />
            </xpath>
        </field>
    </record>
    <!-- Slitting Order Form View -->
    <record id="view_material_slitting_form" model="ir.ui.view">
        <field name="name">my.material.slitting.form</field>
        <field name="model">my.material.slitting</field>
        <field name="arch" type="xml">
            <form string="材料分切单">
                <header>
                    <button name="action_confirm_slitting" string="执行分切" type="object" class="oe_highlight" invisible="state == 'done'" />
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group string="源材料信息">
                            <field name="warehouse_id" />
                            <field name="product_id" />
                            <field name="location_id" />
                            <field name="location_id" />
                            <field name="source_lot_id" domain="[]" context="{'active_test': False}"/>
                            <label string="当前库存" for="source_qty" />
                            <div class="o_row">
                                <field name="source_qty" />
                                <span>(Rolls/Units)</span>
                            </div>
                            <field name="source_width" />
                            <field name="source_length" />
                        </group>
                        <group string="目标位置">
                            <field name="location_dest_id" />
                        </group>
                    </group>
                    <notebook>
                        <page string="分切方案">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="target_width" />
                                    <field name="quantity" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <!-- Slitting Order List View -->
    <record id="view_material_slitting_tree" model="ir.ui.view">
        <field name="name">my.material.slitting.tree</field>
        <field name="model">my.material.slitting</field>
        <field name="arch" type="xml">
            <list string="分切单">
                <field name="name" />
                <field name="product_id" />
                <field name="source_lot_id" />
                <field name="state" />
            </list>
        </field>
    </record>
    <!-- Slitting Order Action -->
    <record id="action_material_slitting" model="ir.actions.act_window">
        <field name="name">材料分切</field>
        <field name="res_model">my.material.slitting</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">创建第一个分切单</p>
        </field>
    </record>
    <!-- Menu Item (Place it under Material or Inventory) -->
    <menuitem id="menu_material_slitting" name="分切管理" parent="menu_my_material_root" action="action_material_slitting" sequence="30" />
</odoo>