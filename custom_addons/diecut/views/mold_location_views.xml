<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 存放位置列表视图 -->
    <record id="view_mold_location_tree" model="ir.ui.view">
        <field name="name">diecut.mold.location.tree</field>
        <field name="model">diecut.mold.location</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- 存放位置表单视图 -->
    <record id="view_mold_location_form" model="ir.ui.view">
        <field name="name">diecut.mold.location.form</field>
        <field name="model">diecut.mold.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 存放位置动作 -->
    <record id="action_mold_location" model="ir.actions.act_window">
        <field name="name">存放位置</field>
        <field name="res_model">diecut.mold.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 菜单项 (放在"模切管理-配置"下) -->
    <menuitem id="menu_mold_location" 
              name="存放位置" 
              parent="menu_diecut_config" 
              action="action_mold_location" 
              sequence="20"/>
</odoo>
