<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 存放位置列表视图 -->
    <record id="view_mold_location_tree" model="ir.ui.view">
        <field name="name">diecut.mold.location.tree</field>
        <field name="model">diecut.mold.location</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- 存放位置表单视图 -->
    <record id="view_mold_location_form" model="ir.ui.view">
        <field name="name">diecut.mold.location.form</field>
        <field name="model">diecut.mold.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

 
</odoo>
