<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_diecut_catalog_series_tree" model="ir.ui.view">
        <field name="name">diecut.catalog.series.tree</field>
        <field name="model">diecut.catalog.series</field>
        <field name="arch" type="xml">
            <list string="系列字典" default_order="brand_id, sequence, name, id">
                <field name="brand_id"/>
                <field name="name"/>
                <field name="sequence" optional="hide"/>
                <field name="linked_item_count" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_catalog_series_form" model="ir.ui.view">
        <field name="name">diecut.catalog.series.form</field>
        <field name="model">diecut.catalog.series</field>
        <field name="arch" type="xml">
            <form string="系列字典">
                <sheet>
                    <group>
                        <group>
                            <field name="brand_id"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="linked_item_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="系列字典内容">
                        <group>
                            <field name="product_features"/>
                        </group>
                        <group>
                            <field name="product_description"/>
                        </group>
                        <group colspan="2">
                            <field name="main_applications" widget="html"/>
                        </group>
                        <group colspan="2" string="默认选型标签">
                            <group>
                                <field name="default_function_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <field name="default_application_tag_ids" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="default_feature_tag_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_diecut_catalog_series_search" model="ir.ui.view">
        <field name="name">diecut.catalog.series.search</field>
        <field name="model">diecut.catalog.series</field>
        <field name="arch" type="xml">
            <search string="系列字典搜索">
                <field name="brand_id"/>
                <field name="name"/>
                <filter name="group_brand" string="按品牌分组" context="{'group_by': 'brand_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_diecut_catalog_series" model="ir.actions.act_window">
        <field name="name">系列字典</field>
        <field name="res_model">diecut.catalog.series</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_diecut_catalog_series_tree"/>
        <field name="search_view_id" ref="view_diecut_catalog_series_search"/>
    </record>
</odoo>
