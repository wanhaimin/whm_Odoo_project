<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_diecut_quote_tree" model="ir.ui.view">
        <field name="name">diecut.quote.list</field>
        <field name="model">diecut.quote</field>
        <field name="arch" type="xml">
            <list string="报价单" decoration-bf="final_unit_price &gt; 0" decoration-info="profit_rate &gt; 0.2" multi_edit="1" editable="bottom">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="project_sn"/>
                <field name="internal_sn"/>
                <field name="quote_date"/>
                <field name="final_unit_price" widget="monetary" options="{'currency_field': 'currency_id'}" decoration-bf="1"/>
                <field name="profit_rate" widget="percentage" decoration-success="profit_rate &gt; 0.15" decoration-danger="profit_rate &lt; 0.05"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="create_date" string="创建时间" optional="hide"/>
                <button name="action_open_form" type="object" icon="fa-external-link" string=" " title="打开详情"/>
            </list>
        </field>
    </record>

    <!-- Form View: Standard Factory Design -->
    <record id="view_diecut_quote_form" model="ir.ui.view">
        <field name="name">diecut.quote.form</field>
        <field name="model">diecut.quote</field>
        <field name="arch" type="xml">
            <form string="报价单">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group name="group_top" col="3">
                        <group name="group_left">
                            <field name="customer_id" options="{'no_create': True}" string='客户'/>
                            <field name="contact_id" domain="[('parent_id', '=', customer_id),('customer_rank', '>', 0)]"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="quote_date"/>                          
                        </group>
                        <group name="group_middle">
                            <field name="product_name"/>
                            <field name="internal_sn" string="料号"/>
                            <field name="specification"/>
                            <field name="project_sn" string="终端项目号 ： "/>
                           
                        </group>
                        <group name="group_right">
                            <field name="moq" string="最小起订量:"/>
                            <field name="lead_time" string="交期:"/>
                            <field name="user_id" widget="many2one_avatar_user" string="制单人"/>   
                        </group>
                    </group>

                    <notebook>
                        <page string="材料成本" name="material_cost">
                            <div class="d-flex justify-content-end mb-2">
                                <div class="btn-group" role="group" aria-label="Bulk Sync Actions">
                                    <button name="action_sync_slitting_width" type="object" string="同步分切宽" class="btn-sm btn-secondary" help="应用首行分切宽到所有行"/>
                                    <button name="action_sync_pitch" type="object" string="同步跳距" class="btn-sm btn-secondary" help="应用首行跳距到所有行"/>
                                    <button name="action_sync_cavity" type="object" string="同步穴数" class="btn-sm btn-secondary" help="应用首行模穴数到所有行"/>
                                    <button name="action_sync_yield_rate" type="object" string="同步良率" class="btn-sm btn-secondary" help="应用首行良率到所有行"/>
                                </div>
                            </div>
                            <field name="material_line_ids" mode="list">
                                <list editable="bottom" multi_edit="1">
                                    <field name="material_id" width="200px"/>
                                    <field name="raw_width" string="原材宽" optional="show"/>
                                    <field name="raw_length" string="原材长" optional="show"/>
                                    <field name="price_unit_tax_inc" string="含税单价"/>
                                    <field name="slitting_rolls" optional="show"/>
                                    <field name="qty_per_roll" optional="show"/>
                                    <field name="slitting_width" string="分切宽"/>
                                    <field name="pitch"/>
                                    <field name="cavity"/>
                                    <field name="unit_usage" optional="show" digits="[12,6]"/>
                                    <field name="yield_rate" widget="percentage" optional="show"/>
                                    <field name="unit_consumable_cost" sum="Total" decoration-bf="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="material_cost_ratio" widget="percentage"/>
                                <field name="total_material_cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>
                        
                        <page string="制造成本" name="manufacturing_cost">
                            <field name="manufacturing_line_ids" mode="list">
                                <list editable="bottom">
                                    <field name="step_1" width="150px"/>
                                    <field name="step_2" width="200px"/>
                                    <field name="mfg_fee" string="工费/H"/>
                                    <field name="workstation_qty" string="人数"/>
                                    <field name="capacity"/>
                                    <field name="yield_rate" widget="percentage"/>
                                    <field name="cost_per_pcs" sum="Total" decoration-bf="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_manufacturing_cost_nosetax" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="total_manufacturing_cost" widget="monetary" options="{'currency_field': 'currency_id'}" string="制造成本(含税)"/>
                            </group>
                        </page>

                        <page string="管销与其他" name="overhead_cost">
                            <div class="row">
                                <div class="col-md-6">
                                    <group string="管销费率摊销">
                                        <field name="transport_rate" widget="percentage"/>
                                        <field name="management_rate" widget="percentage"/>
                                        <field name="utility_rate" widget="percentage"/>
                                        <field name="packaging_rate" widget="percentage"/>
                                        <field name="depreciation_rate" widget="percentage"/>
                                        <field name="total_marketing_cost" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_subtotal_footer_separator"/>
                                    </group>
                                </div>
                                <div class="col-md-6">
                                    <group string="其它费用摊销">
                                        <field name="mold_fee" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        <label for="punch_qty" string="分摊数量"/>
                                        <div class="o_row">
                                            <field name="punch_qty"/> 
                                            <span>-> <field name="mold_cost" widget="monetary" nolabel="1"/></span>
                                        </div>
                                        <field name="sample_cost_input" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        <field name="total_other_cost" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_subtotal_footer_separator"/>
                                    </group>
                                </div>
                            </div>
                        </page>
                    </notebook>

                    <group class="oe_subtotal_footer oe_right">
                        <field name="subtotal_cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        
                        <label for="profit_rate"/>
                        <div class="o_row">
                            <field name="profit_rate" class="oe_inline"/>
                            <span>-> <field name="profit_amount" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_inline"/></span>
                        </div>
                        
                        <div class="oe_subtotal_footer_separator oe_inline">
                            <label for="final_unit_price"/>
                        </div>
                        <field name="final_unit_price" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}" style="font-size: 1.5em;"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search / Action / Menu unchanged -->
    <record id="view_diecut_quote_search" model="ir.ui.view">
        <field name="name">diecut.quote.search</field>
        <field name="model">diecut.quote</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id" />
                <field name="project_sn"/>
                <field name="internal_sn"/>
            </search>
        </field>
    </record>

    <record id="action_diecut_quote" model="ir.actions.act_window">
        <field name="name">成本计算器</field>
        <field name="res_model">diecut.quote</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">创建一个新的模切成本估算报价。</p>
        </field>
    </record>



  
</odoo>
