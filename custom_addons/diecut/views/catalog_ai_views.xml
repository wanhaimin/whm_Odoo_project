<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_diecut_catalog_param_category_tree" model="ir.ui.view">
        <field name="name">diecut.catalog.param.category.tree</field>
        <field name="model">diecut.catalog.param.category</field>
        <field name="arch" type="xml">
            <list string="参数分类" default_order="sequence, id">
                <field name="sequence" optional="hide"/>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <field name="param_count" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_catalog_param_category_form" model="ir.ui.view">
        <field name="name">diecut.catalog.param.category.form</field>
        <field name="model">diecut.catalog.param.category</field>
        <field name="arch" type="xml">
            <form string="参数分类">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="param_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_diecut_catalog_param_category_search" model="ir.ui.view">
        <field name="name">diecut.catalog.param.category.search</field>
        <field name="model">diecut.catalog.param.category</field>
        <field name="arch" type="xml">
            <search string="参数分类搜索">
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <filter name="filter_active" string="启用" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_diecut_catalog_param_category" model="ir.actions.act_window">
        <field name="name">参数分类</field>
        <field name="res_model">diecut.catalog.param.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_diecut_catalog_param_category_search"/>
    </record>

    <record id="view_diecut_catalog_source_document_tree" model="ir.ui.view">
        <field name="name">diecut.catalog.source.document.tree</field>
        <field name="model">diecut.catalog.source.document</field>
        <field name="arch" type="xml">
            <list string="AI/TDS 草稿" default_order="create_date desc, id desc">
                <field name="name"/>
                <field name="source_type"/>
                <field name="brand_id"/>
                <field name="categ_id" optional="show"/>
                <field name="primary_attachment_name" optional="show"/>
                <field name="parse_version" optional="show"/>
                <field name="import_status"/>
                <field name="line_count" optional="show"/>
                <field name="create_date" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_diecut_catalog_source_document_form" model="ir.ui.view">
        <field name="name">diecut.catalog.source.document.form</field>
        <field name="model">diecut.catalog.source.document</field>
        <field name="arch" type="xml">
            <form string="AI/TDS 草稿">
                <header>
                    <button name="action_extract_source" string="提取原文" type="object" class="btn btn-secondary" invisible="import_status in ('applied', 'validated')"/>
                    <button name="action_generate_draft" string="AI生成草稿" type="object" class="oe_highlight" invisible="import_status == 'applied'"/>
                    <button name="action_refresh_draft_editor" string="刷新草稿编辑器" type="object" class="btn btn-secondary" invisible="not draft_payload"/>
                    <button name="action_save_draft_editor" string="保存草稿编辑" type="object" class="btn btn-secondary" invisible="not draft_payload"/>
                    <button name="action_validate_draft" string="校验草稿" type="object" class="btn btn-secondary" invisible="import_status == 'applied'"/>
                    <button name="action_apply_draft" string="入库草稿" type="object" class="btn btn-primary" invisible="import_status == 'applied'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source_type"/>
                            <field name="brand_id"/>
                            <field name="categ_id"/>
                            <field name="skill_profile"/>
                            <field name="brand_skill_name"/>
                            <field name="source_url" invisible="source_type != 'url'"/>
                            <field name="source_file" filename="source_filename" invisible="source_type == 'url'"/>
                            <field name="source_filename" invisible="1"/>
                            <field name="primary_attachment_id"/>
                            <field name="attachment_count" readonly="1"/>
                            <field name="primary_attachment_name" readonly="1"/>
                            <field name="primary_attachment_mimetype" readonly="1"/>
                        </group>
                        <group>
                            <field name="parse_version"/>
                            <field name="import_status"/>
                            <field name="line_count" readonly="1"/>
                            <field name="active"/>
                            <field name="extracted_image" widget="image" filename="extracted_image_filename"/>
                            <field name="extracted_image_filename" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="操作指南">
                            <group col="1">
                                <div class="o_form_label">1. 上传 PDF、图片或网页来源，并确认主解析附件。</div>
                                <div class="o_form_label">2. 点击“提取原文”，走 OpenClaw agent/cli 链路提取正文和图片附件。</div>
                                <div class="o_form_label">3. 点击“AI生成草稿”，由 OpenClaw 直接生成结构化草稿。</div>
                                <div class="o_form_label">4. 在“草稿编辑”页核对主表字段、系列信息和技术参数，必要时手动修订。</div>
                                <div class="o_form_label">5. 点击“校验草稿”，确认无误后再人工执行“入库草稿”。</div>
                            </group>
                        </page>
                        <page string="草稿编辑">
                            <group col="1">
                                <field name="draft_editor_note" nolabel="1" readonly="1"/>
                            </group>
                            <group string="基础属性" col="2">
                                <group>
                                    <field name="brand_id"/>
                                    <field name="categ_id"/>
                                    <field name="draft_item_name"/>
                                    <field name="draft_item_code"/>
                                    <field name="draft_series_name"/>
                                    <field name="draft_catalog_status"/>
                                    <field name="draft_manufacturer_name"/>
                                </group>
                                <group>
                                    <field name="draft_thickness"/>
                                    <field name="draft_thickness_std"/>
                                    <field name="draft_adhesive_thickness"/>
                                    <field name="draft_color_name"/>
                                    <field name="draft_adhesive_type_name"/>
                                    <field name="draft_base_material_name"/>
                                    <field name="draft_ref_price"/>
                                    <field name="draft_is_rohs"/>
                                    <field name="draft_is_reach"/>
                                    <field name="draft_is_halogen_free"/>
                                    <field name="draft_fire_rating"/>
                                </group>
                            </group>
                            <group string="选型信息" col="2">
                                <group>
                                    <field name="draft_product_features"/>
                                    <field name="draft_product_description"/>
                                </group>
                                <group>
                                    <field name="draft_main_applications" widget="html"/>
                                </group>
                            </group>
                            <group string="技术参数" col="1">
                                <field name="draft_line_ids" nolabel="1">
                                    <list editable="bottom" default_order="sequence, id">
                                        <field name="sequence" optional="hide"/>
                                        <field name="item_code" optional="show"/>
                                        <field name="param_key"/>
                                        <field name="param_name"/>
                                        <field name="spec_category_name" optional="show"/>
                                        <field name="dictionary_status"/>
                                        <field name="route_label" optional="show" readonly="1"/>
                                        <field name="value_display"/>
                                        <field name="unit"/>
                                        <field name="condition_summary" optional="show"/>
                                        <field name="test_method" optional="show"/>
                                        <field name="test_condition" optional="show"/>
                                        <field name="remark" optional="show"/>
                                        <field name="source_label" optional="show" readonly="1"/>
                                        <field name="preferred_unit" optional="hide"/>
                                        <field name="source_key" optional="hide"/>
                                        <field name="candidate_new" optional="hide"/>
                                        <field name="is_main_field" optional="hide"/>
                                        <field name="main_field_name" optional="hide"/>
                                        <field name="value_type" optional="hide"/>
                                    </list>
                                    <form string="草稿参数编辑">
                                        <group>
                                            <group>
                                                <field name="item_code"/>
                                                <field name="param_key"/>
                                                <field name="param_name"/>
                                                <field name="spec_category_name"/>
                                                <field name="dictionary_status"/>
                                                <field name="route_label" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="value_display"/>
                                                <field name="unit"/>
                                                <field name="condition_summary"/>
                                                <field name="test_method"/>
                                                <field name="test_condition"/>
                                                <field name="source_label" readonly="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="remark"/>
                                            <field name="method_html" widget="html" readonly="1"/>
                                        </group>
                                    </form>
                                </field>
                            </group>
                        </page>
                        <page string="原始 JSON">
                            <group>
                                <field name="draft_payload" nolabel="1" widget="text" placeholder='{"series": [], "items": [], "params": [], "category_params": [], "spec_values": [], "unmatched": []}'/>
                            </group>
                        </page>
                        <page string="处理结果">
                            <group>
                                <field name="result_message" nolabel="1" readonly="1"/>
                                <field name="unmatched_payload" nolabel="1" readonly="1"/>
                            </group>
                        </page>
                        <page string="Copilot 上下文">
                            <group>
                                <field name="context_used" nolabel="1" widget="text" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_diecut_catalog_source_document_search" model="ir.ui.view">
        <field name="name">diecut.catalog.source.document.search</field>
        <field name="model">diecut.catalog.source.document</field>
        <field name="arch" type="xml">
            <search string="AI/TDS 草稿搜索">
                <field name="name"/>
                <field name="brand_id"/>
                <field name="categ_id"/>
                <field name="source_type"/>
                <field name="import_status"/>
                <filter name="filter_pending" string="待确认" domain="[('import_status', 'in', ('draft', 'extracted', 'generated', 'review'))]"/>
                <filter name="filter_applied" string="已入库" domain="[('import_status', '=', 'applied')]"/>
                <separator/>
                <filter name="group_brand" string="按品牌分组" context="{'group_by': 'brand_id'}"/>
                <filter name="group_status" string="按状态分组" context="{'group_by': 'import_status'}"/>
            </search>
        </field>
    </record>

    <record id="action_diecut_catalog_source_document" model="ir.actions.act_window">
        <field name="name">AI/TDS 草稿</field>
        <field name="res_model">diecut.catalog.source.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_diecut_catalog_source_document_search"/>
    </record>
</odoo>
