<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_requisition_form" model="ir.ui.view">
        <field name="name">my.material.requisition.form</field>
        <field name="model">my.material.requisition</field>
        <field name="arch" type="xml">
            <form string="领料演示单">
                <sheet>
                    <group>
                        <group string="领料信息">
                            <field name="material_id"/>
                            <field name="quantity"/>
                            <field name="total_price"/>
                        </group>
                        <group string="自动抓取的材料参数">
                            <field name="spec"/>
                            <field name="thickness"/>
                            <field name="width"/>
                            <field name="length"/>
                            <field name="uom_name"/>
                            <field name="unit_price"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_requisition_tree" model="ir.ui.view">
        <field name="name">my.material.requisition.tree</field>
        <field name="model">my.material.requisition</field>
        <field name="arch" type="xml">
            <list string="领料单列表">
                <field name="material_id"/>
                <field name="quantity"/>
                <field name="total_price"/>
                <field name="unit_price"/>
            </list>
        </field>
    </record>

    <record id="action_requisition_demo" model="ir.actions.act_window">
        <field name="name">领料演示 (自动填充)</field>
        <field name="res_model">my.material.requisition</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu moved to diecut_menu_view.xml -->
</odoo>
