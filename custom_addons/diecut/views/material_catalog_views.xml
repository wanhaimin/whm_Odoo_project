<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================== -->
    <!-- 1. 选型目录 Form View (系列详情 + 变体技术参数对比表)       -->
    <!-- ========================================================== -->
    <record id="view_material_catalog_form" model="ir.ui.view">
        <field name="name">material.catalog.form</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form string="材料选型目录">
                <header>
                    <button name="action_submit_review" string="提交评审" type="object" class="btn-secondary" invisible="catalog_status != 'draft'" />
                    <button name="action_publish_catalog" string="发布" type="object" class="btn-primary" invisible="catalog_status not in ('draft','review')" />
                    <button name="action_set_catalog_draft" string="退回草稿" type="object" class="btn-secondary" invisible="catalog_status == 'draft'" />
                    <button name="action_deprecate_catalog" string="标记停产" type="object" class="btn-secondary" invisible="catalog_status == 'deprecated'" />
                    <field name="catalog_status" widget="statusbar" statusbar_visible="draft,review,published,deprecated" />
                </header>
                <sheet>
                    <!-- 顶部标志区 -->
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_detail" string="变体" type="object" class="oe_stat_button" icon="fa-cubes" invisible="product_variant_count == 0">
                            <field name="product_variant_count" string="型号数" widget="statinfo" />
                        </button>
                    </div>
                    <widget name="web_ribbon" title="已停产" bg_color="text-bg-danger" invisible="catalog_status != 'deprecated'" />
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="系列名称，如：Sidike PET双面胶 DST系列" />
                        </h1>
                    </div>
                    <!-- 核心信息美化排版 (Bootstrap 5 栅格与卡片方案) -->
                    <div class="row mt-4 mb-4 g-3">
                        <!-- 左侧：基本信息 -->
                        <div class="col-12 col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body">
                                    <h4 class="card-title text-primary fw-bold mb-3">
                                        <i class="fa fa-tags me-2" />
                                        基本信息
                                    </h4>
                                    <group>
                                        <field name="brand_id" />
                                        <field name="manufacturer_id" string="生产厂家" context="{'default_is_company': True}" />
                                        <field name="series_name" placeholder="如：PET Double Sided Tape" />
                                        <field name="recommendation_level" />
                                        <field name="categ_id" string="材料分类" domain="[('category_type', '=', 'raw')]" />
                                        <field name="variant_color_std_index" string="所有型号包含颜色" readonly="1" help="该字段由下方的型号对比表自动汇总，无需手动填写" />
                                    </group>
                                </div>
                            </div>
                        </div>
                        <!-- 中间：产品特点 -->
                        <div class="col-12 col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body">
                                    <h4 class="card-title text-success fw-bold mb-3">
                                        <i class="fa fa-star me-2" />
                                        产品特点
                                    </h4>
                                    <group>
                                        <field name="catalog_characteristics" string="核心特性" placeholder="如：耐化学腐蚀, 重工性" />
                                    </group>
                                    <div class="mt-3">
                                        <span class="text-muted fw-bold d-block mb-2">详细说明</span>
                                        <field name="catalog_features" nolabel="1" class="w-100" placeholder="如：以PET为基材，双面涂布压敏胶水，具有良好的抗拉强度..." />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- 右侧：典型应用 -->
                        <div class="col-12 col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body">
                                    <h4 class="card-title text-info fw-bold mb-3">
                                        <i class="fa fa-cogs me-2" />
                                        典型应用
                                    </h4>
                                    <div class="d-flex flex-column h-100">
                                        <field name="catalog_applications" nolabel="1" class="flex-grow-1 w-100" placeholder="如：LCD铭板粘接、手机部件固定..." />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    >
                    <notebook>
                        <!-- ★★★ 核心标签页：型号变体对比表 ★★★ -->
                        <page name="variant_specs" string="型号对比表">
                            <field name="product_variant_ids" nolabel="1">
                                <list string="型号技术参数" editable="bottom">
                                    <field name="default_code" string="型号" />
                                    <field name="variant_base_material" string="基材" optional="show" />
                                    <field name="variant_adhesive_type" string="胶系" optional="show" />
                                    <field name="variant_thickness" string="厚度" />
                                    <field name="variant_adhesive_thickness" string="胶厚" optional="show" />
                                    <field name="variant_color" string="颜色" optional="show" />
                                    <field name="variant_base_material_std" optional="hide" />
                                    <field name="variant_adhesive_std" optional="hide" />
                                    <field name="variant_thickness_std" optional="hide" />
                                    <field name="variant_color_std" optional="hide" />
                                    <field name="variant_peel_strength" />
                                    <field name="variant_structure" optional="show" />
                                    <field name="variant_ref_price" optional="show" />
                                    <field name="variant_sus_peel" optional="hide" />
                                    <field name="variant_pe_peel" optional="hide" />
                                    <field name="variant_dupont" optional="hide" />
                                    <field name="variant_push_force" string="推出力" optional="hide" />
                                    <field name="variant_removability" string="可移除性" optional="hide" />
                                    <field name="variant_tumbler" optional="hide" />
                                    <field name="variant_holding_power" optional="hide" />
                                    <field name="variant_note" optional="hide" />
                                    <field name="is_activated" column_invisible="True" />
                                    <button name="action_activate_to_erp" string="🚀 启用到ERP" type="object" class="btn-primary" invisible="is_activated" />
                                    <button name="action_view_erp_product" string="✅ 已启用" type="object" class="btn-success" invisible="not is_activated" />
                                </list>
                            </field>
                        </page>
                        <!-- 属性与变体配置 -->
                        <page name="variant_config" string="属性与变体配置">
                            <group string="产品属性（用于生成变体）">
                                <field name="attribute_line_ids" nolabel="1" colspan="2">
                                    <list editable="bottom">
                                        <field name="attribute_id" />
                                        <field name="value_ids" widget="many2many_tags" />
                                    </list>
                                </field>
                            </group>
                        </page>
                        <!-- 动态物理特性 -->
                        <page name="dynamic_props" string="动态物理特性">
                            <group string="动态物理特性（继承自材料分类）">
                                <field name="diecut_properties" widget="properties" nolabel="1" colspan="2" />
                            </group>
                        </page>
                        <!-- 认证与合规（系列默认；各型号可在型号详情页单独维护） -->
                        <page name="certification" string="认证与合规">
                            <group>
                                <group string="系列默认（各型号可在型号详情页填独立值）">
                                    <field name="is_rohs" />
                                    <field name="is_reach" />
                                    <field name="is_halogen_free" />
                                    <field name="fire_rating" />
                                </group>
                            </group>
                        </page>
                        <page name="replacement" string="替代建议">
                            <group>
                                <group string="系列默认可替代系列（各型号可在型号详情页填独立值）">
                                    <field name="replacement_catalog_ids" widget="many2many_tags" domain="[('is_catalog', '=', True), ('id', '!=', id)]" options="{'no_create': True}" />
                                </group>
                                <group string="被以下系列替代">
                                    <field name="replaced_by_catalog_ids" widget="many2many_tags" readonly="1" options="{'no_create': True}" />
                                </group>
                            </group>
                        </page>
                        <!-- 附件与资料（系列默认；各型号可在型号详情页上传独立附件） -->
                        <page name="attachments" string="附件与资料">
                            <group>
                                <group string="技术文档">
                                    <field name="tds_filename" invisible="1" />
                                    <field name="tds_file" string="TDS 技术数据表" filename="tds_filename" />
                                    <field name="msds_filename" invisible="1" />
                                    <field name="msds_file" string="MSDS 安全数据表" filename="msds_filename" />
                                    <field name="datasheet_filename" invisible="1" />
                                    <field name="datasheet" string="规格书" filename="datasheet_filename" />
                                </group>
                                <group string="结构图">
                                    <field name="catalog_structure_image" widget="image" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <!-- 隐藏字段 -->
                    <field name="is_catalog" invisible="1" />
                    <field name="is_raw_material" invisible="1" />
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <!-- ========================================================== -->
    <!-- 2. 选型目录 List View (系列级快速浏览)                     -->
    <!-- ========================================================== -->
    <record id="view_material_catalog_tree" model="ir.ui.view">
        <field name="name">material.catalog.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="材料选型目录">
                <field name="name" string="系列名称" />
                <field name="brand_id" />
                <field name="categ_id" string="分类" />
                <field name="recommendation_level" optional="show" />
                <field name="catalog_characteristics" string="特性" optional="show" />
                <field name="catalog_base_material" optional="show" />
                <field name="catalog_adhesive_type" optional="show" />
                <field name="variant_base_material_std_index" string="型号基材" optional="hide" />
                <field name="variant_adhesive_std_index" string="型号胶系" optional="hide" />
                <field name="variant_thickness_std_index" string="型号厚度" optional="hide" />
                <field name="variant_color_std_index" string="型号颜色" optional="hide" />
                <field name="manufacturer_id" string="厂家" optional="hide" />
                <field name="product_variant_count" string="型号数" />
                <field name="catalog_ref_price" string="参考价" optional="hide" />
                <field name="diecut_properties" optional="hide" />
                <field name="catalog_status" string="状态" widget="badge" decoration-success="catalog_status == 'published'" decoration-info="catalog_status == 'review'" decoration-warning="catalog_status == 'draft'" decoration-danger="catalog_status == 'deprecated'" />
            </list>
        </field>
    </record>
    <!-- ========================================================== -->
    <!-- 3. 选型目录 Search View                                    -->
    <!-- ========================================================== -->
    <record id="view_material_catalog_search" model="ir.ui.view">
        <field name="name">material.catalog.search</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search>
                <!-- 搜索框字段 -->
                <field name="name" string="系列名称/编码" filter_domain="['|', '|', ('default_code', 'ilike', self), ('name', 'ilike', self), ('series_name', 'ilike', self)]" />
                <field name="brand_id" string="品牌" />
                <field name="catalog_base_material" string="基材" />
                <field name="catalog_adhesive_type" string="胶系" />
                <field name="variant_base_material_std_index" string="型号基材" />
                <field name="variant_adhesive_std_index" string="型号胶系" />
                <field name="variant_thickness_std_index" string="型号厚度" />
                <field name="variant_color_std_index" string="型号颜色" />
                <field name="manufacturer_id" string="厂家" />
                <!-- 状态过滤器 -->
                <filter name="filter_published" string="已发布" domain="[('catalog_status', '=', 'published')]" />
                <filter name="filter_review" string="评审中" domain="[('catalog_status', '=', 'review')]" />
                <filter name="filter_draft" string="草稿" domain="[('catalog_status', '=', 'draft')]" />
                <filter name="filter_deprecated" string="已停产" domain="[('catalog_status', '=', 'deprecated')]" />
                <separator />
                <filter name="filter_rohs" string="ROHS" domain="[('is_rohs', '=', True)]" />
                <filter name="filter_reach" string="REACH" domain="[('is_reach', '=', True)]" />
                <filter name="filter_halogen_free" string="无卤" domain="[('is_halogen_free', '=', True)]" />
                <!-- 分组 -->
                <separator />
                <filter name="group_by_brand" string="品牌" context="{'group_by': 'brand_id'}" />
                <filter name="group_by_categ" string="分类" context="{'group_by': 'categ_id'}" />
                <filter name="group_by_manufacturer" string="厂家" context="{'group_by': 'manufacturer_id'}" />
                <filter name="group_by_base_material" string="基材" context="{'group_by': 'catalog_base_material'}" />
                <filter name="group_by_variant_base_material" string="型号基材" context="{'group_by': 'variant_base_material_std_index'}" />
                <filter name="group_by_variant_adhesive" string="型号胶系" context="{'group_by': 'variant_adhesive_std_index'}" />
                <filter name="group_by_variant_thickness" string="型号厚度" context="{'group_by': 'variant_thickness_std_index'}" />
                <filter name="group_by_variant_color" string="型号颜色" context="{'group_by': 'variant_color_std_index'}" />
                <filter name="group_by_recommendation" string="推荐等级" context="{'group_by': 'recommendation_level'}" />
                <filter name="group_by_status" string="状态" context="{'group_by': 'catalog_status'}" />
                <!-- 左侧搜索面板 -->
                <searchpanel>
                    <field name="categ_id" string="材质分类" enable_counters="1" icon="fa-list" hierarchize="1" expand="1" />
                    <field name="brand_id" string="品牌" select="multi" enable_counters="1" icon="fa-cube" />
                </searchpanel>
            </search>
        </field>
    </record>
    <!-- ========================================================== -->
    <!-- 4. 选型目录 Action                                         -->
    <!-- ========================================================== -->
    <record id="action_material_catalog" model="ir.actions.act_window">
        <field name="name">材料选型大全</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_catalog', '=', True)]</field>
        <field name="context">{
            'default_is_catalog': True,
            'default_purchase_ok': False,
            'default_sale_ok': False,
            'default_type': 'consu',
            'search_default_filter_published': 1,
        }</field>
        <field name="search_view_id" ref="view_material_catalog_search" />
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_material_catalog_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_material_catalog_form')})]" />
    </record>

    <record id="action_material_catalog_create_template" model="ir.actions.act_window">
        <field name="name">新建材料系列</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_catalog', '=', True)]</field>
        <field name="target">current</field>
        <field name="context">{
            'default_is_catalog': True,
            'default_purchase_ok': False,
            'default_sale_ok': False,
            'default_type': 'consu',
            'form_view_initial_mode': 'edit'
        }</field>
        <field name="search_view_id" ref="view_material_catalog_search" />
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_material_catalog_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_material_catalog_form')})]" />
    </record>
    <!-- ========================================================== -->
    <!-- 5. 型号清单（变体级）                                      -->
    <!-- ========================================================== -->
    <record id="view_material_catalog_variant_tree" model="ir.ui.view">
        <field name="name">material.catalog.variant.tree</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list string="材料型号清单">
                <field name="default_code" string="型号" />
                <field name="product_tmpl_id" string="系列" />
                <field name="catalog_brand_id" string="品牌" optional="show" />
                <field name="catalog_categ_id" string="分类" optional="show" />
                <field name="catalog_characteristics" string="特性" optional="show" />
                <field name="variant_base_material" string="基材" optional="show" />
                <field name="variant_adhesive_type" string="胶系" optional="show" />
                <field name="variant_thickness" string="厚度" />
                <field name="variant_adhesive_thickness" string="胶厚" optional="show" />
                <field name="variant_color" string="颜色" optional="show" />
                <field name="variant_peel_strength" string="剥离力" optional="show" />
                <field name="catalog_density" string="密度(g/cm³)" optional="hide" />
                <field name="catalog_status" string="状态" widget="badge" decoration-success="catalog_status == 'published'" decoration-info="catalog_status == 'review'" decoration-warning="catalog_status == 'draft'" decoration-danger="catalog_status == 'deprecated'" />
                <field name="is_activated" string="已启用ERP" widget="boolean_toggle" optional="show" />
                <button name="action_activate_to_erp" string="🚀 启用到ERP" type="object" class="btn-primary" invisible="is_activated" />
                <button name="action_view_erp_product" string="✅ 已启用" type="object" class="btn-success" invisible="not is_activated" />
            </list>
        </field>
    </record>

    <record id="view_material_catalog_variant_search" model="ir.ui.view">
        <field name="name">material.catalog.variant.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="default_code" string="型号" />
                <field name="product_tmpl_id" string="系列" />
                <field name="catalog_brand_id" string="品牌" />
                <field name="catalog_categ_id" string="分类" />
                <field name="variant_base_material" string="基材" />
                <field name="variant_adhesive_type" string="胶系" />
                <field name="variant_thickness" string="厚度" />
                <field name="variant_color" string="颜色" />
                <filter name="filter_variant_published" string="已发布" domain="[('catalog_status', '=', 'published')]" />
                <filter name="filter_variant_review" string="评审中" domain="[('catalog_status', '=', 'review')]" />
                <filter name="filter_variant_draft" string="草稿" domain="[('catalog_status', '=', 'draft')]" />
                <filter name="filter_variant_deprecated" string="已停产" domain="[('catalog_status', '=', 'deprecated')]" />
                <separator />
                <filter name="group_variant_series" string="按系列" context="{'group_by': 'product_tmpl_id'}" />
                <filter name="group_variant_thickness" string="按厚度" context="{'group_by': 'variant_thickness'}" />
                <filter name="group_variant_color" string="按颜色" context="{'group_by': 'variant_color'}" />
                <filter name="group_variant_adhesive" string="按胶系" context="{'group_by': 'variant_adhesive_type'}" />
                <searchpanel>
                    <field name="catalog_categ_id" string="材料分类" hierarchize="1" enable_counters="1" icon="fa-list" />
                    <field name="catalog_brand_id" string="品牌" select="multi" enable_counters="1" icon="fa-cube" />
                </searchpanel>
            </search>
        </field>
    </record>
    <!-- 变体详细与规格页：从材料型号清单打开单条型号时使用 -->
    <record id="view_material_catalog_variant_form" model="ir.ui.view">
        <field name="name">material.catalog.variant.form</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <form string="型号详情与规格">
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_activate_to_erp" string="启用到ERP" type="object" class="oe_stat_button" icon="fa-cube" invisible="is_activated" />
                        <button name="action_view_erp_product" string="已启用产品" type="object" class="oe_stat_button" icon="fa-external-link" invisible="not is_activated" />
                    </div>
                    <widget name="web_ribbon" title="已停产" bg_color="text-bg-danger" invisible="catalog_status != 'deprecated'" />
                    <div class="row">
                        <div class="col-12 col-lg-4">
                            <field name="variant_catalog_structure_image" widget="image" class="oe_avatar" options="{'size': [300, 300]}" invisible="not variant_catalog_structure_image" />
                            <field name="catalog_structure_image" widget="image" class="oe_avatar" options="{'size': [300, 300]}" invisible="variant_catalog_structure_image" />
                            <field name="image_1920" widget="image" class="oe_avatar" options="{'size': [300, 300]}" invisible="variant_catalog_structure_image or catalog_structure_image" />
                        </div>
                        <div class="col-12 col-lg-8">
                            <h1 class="mb-2">
                                <field name="default_code" readonly="1" class="fw-bold" />
                            </h1>
                            <p class="text-muted mb-1">
                                <field name="product_tmpl_id" readonly="1" nolabel="1" />
                            </p>
                            <group string="产品描述" colspan="2">
                                <field name="catalog_features" nolabel="1" readonly="1" />
                            </group>
                        </div>
                    </div>
                    <group string="主要应用" colspan="2">
                        <field name="catalog_applications" nolabel="1" readonly="1" />
                    </group>
                    <group string="技术特性">
                        <group>
                            <field name="variant_base_material" string="基材" />
                            <field name="variant_thickness" string="总厚度" />
                            <field name="variant_adhesive_type" string="胶粘剂类型" />
                            <field name="variant_color" string="颜色" />
                        </group>
                        <group>
                            <field name="catalog_brand_id" string="品牌" />
                            <field name="catalog_categ_id" string="材料分类" />
                            <field name="recommendation_level" string="推荐等级" />
                        </group>
                    </group>
                    <group string="型号技术参数">
                        <group>
                            <field name="variant_peel_strength" string="剥离力" />
                            <field name="variant_adhesive_thickness" string="胶厚" />
                            <field name="variant_structure" string="结构描述" />
                            <field name="catalog_density" string="密度(g/cm³)" />
                        </group>
                        <group>
                            <field name="variant_sus_peel" string="SUS面剥离力" />
                            <field name="variant_pe_peel" string="PE面剥离力" />
                            <field name="variant_holding_power" string="保持力" />
                            <field name="variant_push_force" string="推出力" />
                            <field name="variant_removability" string="可移除性" />
                            <field name="variant_dupont" string="DuPont冲击" />
                            <field name="variant_ref_price" string="参考单价" />
                        </group>
                    </group>
                    <notebook>
                        <page name="performance" string="特性评级">
                            <group string="变体动态物理特性（定义来自材料分类，此处仅可编辑值；分类在系列表单中配置）">
                                <field name="catalog_categ_id" invisible="1" />
                                <field name="variant_diecut_properties" widget="properties" nolabel="1" colspan="2" />
                            </group>
                        </page>
                        <page name="adhesion" string="粘合特性">
                            <group string="粘合数据（可在此维护或后续扩展为结构化数据）">
                                <field name="variant_note" nolabel="1" placeholder="如：ABS/铝/PC等基材的初始与14天后粘接强度(N/cm)…" />
                            </group>
                        </page>
                        <page name="certification" string="认证与合规">
                            <group string="该型号独立认证与合规">
                                <field name="variant_is_rohs" />
                                <field name="variant_is_reach" />
                                <field name="variant_is_halogen_free" />
                                <field name="variant_fire_rating" />
                            </group>
                        </page>
                        <page name="replacement" string="替代建议">
                            <group string="该型号可替代系列">
                                <field name="variant_replacement_catalog_ids" widget="many2many_tags" nolabel="1" options="{'no_create': True}" />
                            </group>
                        </page>
                        <page name="docs" string="附件与资料">
                            <group>
                                <group string="技术文档（该型号独立）">
                                    <field name="variant_tds_filename" invisible="1" />
                                    <field name="variant_tds_file" string="TDS 技术数据表" filename="variant_tds_filename" />
                                    <field name="variant_msds_filename" invisible="1" />
                                    <field name="variant_msds_file" string="MSDS 安全数据表" filename="variant_msds_filename" />
                                    <field name="variant_datasheet_filename" invisible="1" />
                                    <field name="variant_datasheet" string="规格书" filename="variant_datasheet_filename" />
                                </group>
                                <group string="结构图（该型号独立）">
                                    <field name="variant_catalog_structure_image" widget="image" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <field name="is_activated" invisible="1" />
                    <field name="catalog_status" invisible="1" />
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="action_material_catalog_variant" model="ir.actions.act_window">
        <field name="name">材料型号清单</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('product_tmpl_id.is_catalog', '=', True)]</field>
        <field name="search_view_id" ref="view_material_catalog_variant_search" />
        <field name="context">{'search_default_filter_variant_published': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_material_catalog_variant_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_material_catalog_variant_form')})]" />
    </record>
</odoo>