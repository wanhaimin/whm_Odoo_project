<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. For Stock Report / Location Content (Priority 5) -->
    <record id="view_stock_quant_tree_editable_inherit_diecut" model="ir.ui.view">
        <field name="name">stock.quant.tree.editable.inherit.diecut</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <field name="product_id" position="after">
                <field name="dimension_spec" optional="show"/>
            </field>
        </field>
    </record>

    <!-- 2. For Inventory Adjustments (Priority 10) -->
    <record id="view_stock_quant_tree_inventory_inherit_diecut" model="ir.ui.view">
        <field name="name">stock.quant.inventory.tree.inherit.diecut</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <field name="product_id" position="after">
                <field name="dimension_spec" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
