<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_diecut_mold_search" model="ir.ui.view">
        <field name="name">diecut.mold.search</field>
        <field name="model">diecut.mold</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="customer_id"/>
                
                <filter string="已存档" name="filter_archived" domain="[('active', '=', False)]"/>
                <filter string="有效记录" name="filter_active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>
</odoo>
