<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- QC检验向导表单视图 -->
    <record id="view_mold_qc_wizard_form" model="ir.ui.view">
        <field name="name">diecut.mold.qc.wizard.form</field>
        <field name="model">diecut.mold.qc.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>📋 提交QC检验</strong>
                        <p>请指定负责此次QC检验的人员，系统将自动创建任务提醒并发送通知。</p>
                    </div>
                    <group>
                        <field name="mold_id" readonly="1"/>
                        <field name="qc_assigned_to" options="{'no_create': True}"/>
                        <field name="notes" placeholder="可选：填写需要特别注意的检验事项..."/>
                    </group>
                </sheet>
                <footer>
                    <button string="确认提交" name="action_confirm_qc" type="object" class="btn-primary"/>
                    <button string="取消" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
