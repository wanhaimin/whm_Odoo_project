  "series": [
    {
      "series_name": "DC2000",
      "brand_name": "3M",
      "category_name": "",
      "product_description": "Black foam tape designed for the attachment of nameplates, badges and emblems to the exterior of vehicles. Designed to process easily in all die-cutting operations, including high-speed rotary operations. Exhibits high resistance to pluck and torque forces associated with the attachment of nameplates and emblems.\n3M Die-Cuttable Tape Series DC2000 is a black foam tape designed for the attachment of nameplates, badges and emblems to the exterior of vehicles. This tape is designed to process easily in all die-cutting operations, including high-speed rotary operations. 3M Series DC2000 tape exhibits high resistance to pluck and torque (twisting) forces normally associated with the attachment of nameplates and emblems.",
      "product_features": "Excellent adhesion to paint and chrome.\nExcellent torque (twist) resistance.\nFirm core resists twisting forces that may result in detachment of individual letters.\nExcellent resistance to impact in cold weather.\nExcellent adhesion to paint and chrome. Excellent torque (twist) resistance. Firm core resists twisting forces that may result in the detachment of individual letters. Excellent resistance to impact in cold weather.",
      "main_applications": "Attachment of nameplates, badges and emblems to vehicle exteriors.\nLow demand applications whose primary attachment methods are mechanical.\nAttachment of lightweight pillar covers.\nMiscellaneous sealing applications.\nSpoiler applications requiring tape to perform as a gasket.\nNameplates, badges and emblems. Low demand applications whose primary attachment methods are mechanical. Examples include attachment of lightweight pillar covers, miscellaneous sealing applications and spoiler applications that require tape to perform as a gasket.",
      "special_applications": "Construction appears to be protective liner over double acrylic adhesive layers (DL-1 and DL-2) with black acrylic polymer foam core.\nCompatible with rotary, flat bed, and laser die cutting operations, including high-speed rotary operations.\nMaintains pluck adhesion on low surface energy and scratch-/mar-resistant paint systems; demonstrates higher resistance to twisting forces than typical competitive tapes; exceeds 100 hours static shear at 70°C under stated test conditions.\nShelf life is one year from receipt when stored at 4°C–38°C and 0–95% RH; optimum storage is 22°C and 50% RH.\nOne year from date of receipt by customer when stored at 4°C–38°C (40°F–100°F) and 0–95% relative humidity. Optimum storage conditions are 22°C (72°F) and 50% RH.\nRotary, flat bed, and laser die cutting operations.",
      "source_page": null,
      "source_text": null,
      "source_label": "document_meta",
      "confidence": null,
      "review_note": null
    }
