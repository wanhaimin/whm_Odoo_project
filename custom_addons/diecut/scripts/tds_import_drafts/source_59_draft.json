{
  "series": [
    {
      "series_name": "GT7100 Series",
      "brand_name": "3M",
      "category_name": "",
      "product_description": "3M Acrylic Foam Tape GT7100 Series offers very good adhesion performance and high flexibility. These tapes are specifically designed for the attachment of automotive exterior and interior trim applications.",
      "product_features": "Provides final adhesion and holding power to automotive paints and substrates.\nMeets a number of OEM specifications.\nFollows shrinkage and elongation of plastic parts caused by temperature changes and has good stress relaxation properties.\nViscoelastic core stress relaxation allows conformity to complex geometries and excellent wet out.\nDemonstrates excellent adhesive performance at various temperature conditions.\nExcels in weather conditions and offers solvent and high-temperature resistance.",
      "main_applications": "Attachment of automotive exterior trim applications.\nAttachment of automotive interior trim applications.",
      "special_applications": "Construction stack: polyethylene red liner / acrylic pressure sensitive adhesive / acrylic foam / acrylic pressure sensitive adhesive.\nAn extended liner tab is recommended.\nHeat-Bond Tabbing for Non-Silicone Coated Liners: 3M Tabbing Tape 5081 or 5082 (EMEA, Americas).\nHeat-Bond Tabbing for Non-Silicone Coated Liners: 3M Tabbing Tape AM012 (Asia).\nPSA Tabbing for Non-Silicone Coated Liners: 3M Tabbing Tape 5300 (Global).\nPSA Tabbing for Non-Silicone Coated Liners: 3M Tabbing Tape AM926J, AM926JN or 4240, 4240N (Asia).\nConsult application guidelines for detailed product use instructions.\nTypical performance values are for reference only, depend on substrate characteristics and/or paint composition, and should not be used for specification purposes; certificate of analysis should be used for specification values.\nShelf life is three years from date of manufacture when stored at 23°C +/- 2°C and 50% +/- 4% RH. Short uncontrolled transportation periods of a few days or weeks should not impact product performance, but extended storage beyond recommended conditions should be avoided.",
      "source_page": null,
      "source_text": null,
      "source_label": "document_meta",
      "confidence": null,
      "review_note": null
    }
