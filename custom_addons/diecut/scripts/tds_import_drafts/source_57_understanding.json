  "sections": [
    {
      "section_type": "general_description",
      "title": "General Description",
      "scope": "series",
      "source_page": 1,
      "confidence": 0.98,
      "source_text": "3M Acrylic Foam Tape GT7100 Series offers very good adhesion performance and high flexibility. These tapes are specifically designed for the attachment of automotive exterior and interior trim applications."
    },
    {
      "section_type": "features",
      "title": "Key Features",
      "scope": "series",
      "source_page": 1,
      "confidence": 0.97,
      "source_text": "Provides final adhesion and holding power to automotive paints and substrates. Meets a number of OEM specifications. Follows the shrinkage and elongation of the plastic part caused by temperature change and has good stress relaxation properties. Stress relaxation characteristics of the viscoelastic core allow the tape to conform well to complex geometries and deliver excellent wet out. Demonstrates excellent adhesive performance at various temperature conditions. Excels in a variety of weather conditions and offers solvent and high temperature resistance."
    },
    {
      "section_type": "product_construction",
      "title": "Product Construction",
      "scope": "series",
      "source_page": 1,
      "confidence": 0.95,
      "source_text": "Polyethylene Red liner / Acrylic Pressure Sensitive Adhesive / Acrylic Foam / Acrylic Pressure Sensitive Adhesive"
    },
    {
      "section_type": "physical_properties",
      "title": "Physical Properties",
      "scope": "mixed",
      "source_page": 1,
      "confidence": 0.97,
      "source_text": "Product Core Core Color Thickness * Liner Adhesive GT7102 Acrylic Foam Core Gray 0.2 mm Translucent, red, polyethylene liner Acrylic pressure sensitive ... GT7140 4.0 mm *Liner thickness is not included"
    },
    {
      "section_type": "tabbing",
      "title": "Tabbing Method and Liner Types",
      "scope": "series",
      "source_page": 2,
      "confidence": 0.93,
      "source_text": "An extended liner tab is recommended. Heat-Bond Tabbing for Non-Silicone Coated Liners... PSA Tabbing for Non-Silicone Coated Liners..."
    },
    {
      "section_type": "performance_notes",
      "title": "Performance Properties",
      "scope": "series",
      "source_page": 2,
      "confidence": 0.96,
      "source_text": "Typical performance of 3M Acrylic Foam Tape Series GT7100 is shown below. Peel and shear values depend on substrate characteristics and/or paint composition. These values are for reference only, and not to be used for specification purposes. For specification values please see the certificate of analysis."
    },
    {
      "section_type": "test_condition_definitions",
      "title": "Conditions/Test Parameter Definitions",
      "scope": "series",
      "source_page": 2,
      "confidence": 0.98,
      "source_text": "Immediate State = 23°C, 20 minutes; Normal State = 23°C, 24 hours; High Temperature = 23°C, 24 hours -> 80°C; Heat-aging = 23°C, 24 hours -> 80°C, 336 hours -> 23°C, 24 hours; Warm Water Immersion = 23°C, 24 hours -> 40°C water, 336 hours -> 23°C, 24 hours; Gasoline Immersion = 23°C, 24 hours -> Gasoline, 1 hour -> 23°C, 24 hours; Wax-remover immersion = 23°C, 24 hours -> Wax-remover, 1 hour -> 23°C, 24 hours"
    },
    {
      "section_type": "shelf_life_storage",
      "title": "Shelf Life",
      "scope": "series",
      "source_page": 3,
      "confidence": 0.99,
      "source_text": "Three years from date of manufacture when stored at recommended storage condition 23°C +/-2°C and 50% +/-4% relative humidity."
    },
    {
      "section_type": "regulatory",
      "title": "Regulatory Information",
      "scope": "series",
      "source_page": 3,
