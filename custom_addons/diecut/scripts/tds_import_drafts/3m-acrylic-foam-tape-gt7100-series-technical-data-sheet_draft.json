  "series": [
    {
      "series_name": "GT7100 Series",
      "brand_name": "3M",
      "category_name": "",
      "product_description": "Acrylic foam tape series with very good adhesion performance and high flexibility, specifically designed for attachment of automotive exterior and interior trim applications.",
      "product_features": "Provides final adhesion and holding power to automotive paints and substrates.\nMeets a number of OEM specifications.\nAccommodates shrinkage and elongation of plastic parts caused by temperature change.\nHas good stress relaxation properties.\nViscoelastic core conforms to complex geometries and delivers excellent wet out.\nDemonstrates excellent adhesive performance at various temperature conditions.\nOffers weather, solvent, and high temperature resistance.",
      "main_applications": "Attachment of automotive exterior trim applications.\nAttachment of automotive interior trim applications.\n3M Acrylic Foam Tape GT7100 Series offers very good adhesion performance and high flexibility. These tapes are specifically designed for the attachment of automotive exterior and interior trim applications.",
      "special_applications": "Construction stack appears to be polyethylene red liner / acrylic pressure sensitive adhesive / acrylic foam / acrylic pressure sensitive adhesive.\nAn extended liner tab is recommended.\nHeat-bond tabbing for non-silicone coated liners: 3M Tabbing Tape 5081 or 5082 (EMEA, Americas), AM012 (Asia).\nPSA tabbing for non-silicone coated liners: 3M Tabbing Tape 5300 (Global), AM926J/AM926JN/4240/4240N (Asia).\nConsult application guidelines for detailed product use instructions.\nPeel and shear values depend on substrate characteristics and/or paint composition.\nTypical performance values are for reference only and not for specification purposes.\nFor specification values, see certificate of analysis.\nShelf life: three years from date of manufacture under recommended storage condition.\nRecommended storage condition: 23°C ±2°C and 50% ±4% relative humidity.\nShort uncontrolled transportation periods of a few days or weeks should not impact product performance.\nAvoid extended storage beyond recommended conditions.\nThree years from date of manufacture when stored at recommended storage condition 23°C +/- 2°C and 50% +/- 4% relative humidity. 3M Acrylic Foam Tape GT7100 Series should be stored in typical storage conditions for pressure-sensitive adhesives used within the automotive industry. During transportation, storage conditions are uncontrolled for a short period of time (a few days or weeks). This should not impact product performance. However, materials should not be stored in excess of the recommended conditions for extended periods.",
      "source_page": null,
      "source_text": null,
      "source_label": "document_meta",
      "confidence": null,
      "review_note": null
    }
