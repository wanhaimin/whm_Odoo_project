      {
        "section_name": "general_description",
        "section_type": "narrative",
        "scope": "series",
        "source_page": 1,
        "source_text": "3M Acrylic Foam Tape GT7100 Series offers very good adhesion performance and high flexibility. These tapes are specifically designed for the attachment of automotive exterior and interior trim applications.",
        "summary": "Acrylic foam tape series for automotive exterior/interior trim attachment with good adhesion and flexibility.",
        "confidence": 0.98
      },
      {
        "section_name": "features",
        "section_type": "narrative",
        "scope": "series",
        "source_page": 1,
        "source_text": "Provides final adhesion and holding power to automotive paints and substrates; Meets a number of OEM specifications; Follows shrinkage and elongation of plastic parts caused by temperature change and has good stress relaxation properties; viscoelastic core conforms to complex geometries and delivers excellent wet out; excellent adhesive performance at various temperature conditions; weather, solvent and high temperature resistance.",
        "summary": [
          "Final adhesion and holding power to automotive paints and substrates",
          "Meets multiple OEM specifications",
          "Accommodates shrinkage/elongation of plastic parts under temperature change",
          "Good stress relaxation and conformability to complex geometries",
          "Good wet-out",
          "Performance across temperature conditions",
          "Weather, solvent, and high temperature resistance"
        ],
        "confidence": 0.97
      },
      {
