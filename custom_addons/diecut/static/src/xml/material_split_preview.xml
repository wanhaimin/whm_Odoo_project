<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="diecut.SplitListView" t-inherit="web.ListView" t-inherit-mode="primary">
        <xpath expr="//t[@t-set-slot='control-panel-navigation-additional']" position="replace">
            <t t-set-slot="control-panel-navigation-additional">
                <t t-if="!hasSelectedRecords" t-component="searchBarToggler.component" t-props="searchBarToggler.props"/>
                <nav class="o_cp_switch_buttons d-print-none d-inline-flex btn-group" aria-label="布局切换">
                    <button class="btn btn-secondary o_switch_view o_vertical" t-att-class="splitState.layoutMode === 'vertical' ? 'active' : ''" data-tooltip="左右分屏" t-on-click="() => this.setSplitLayoutMode('vertical')">
                        <i class="oi oi-fw oi-panel-right"/>
                    </button>
                    <button class="btn btn-secondary o_switch_view o_horizontal" t-att-class="splitState.layoutMode === 'horizontal' ? 'active' : ''" data-tooltip="上下分屏" t-on-click="() => this.setSplitLayoutMode('horizontal')">
                        <i class="oi oi-fw oi-panel-right o_diecut_oi_rotate_90"/>
                    </button>
                    <button class="btn btn-secondary o_switch_view o_list_only" t-att-class="splitState.layoutMode === 'list' ? 'active' : ''" data-tooltip="仅列表" t-on-click="() => this.setSplitLayoutMode('list')">
                        <i class="oi oi-fw oi-view-list"/>
                    </button>
                </nav>
            </t>
        </xpath>

        <xpath expr="//t[@t-component='props.Renderer']" position="attributes">
            <attribute name="splitLayoutMode">splitState.layoutMode</attribute>
            <attribute name="splitRatio">splitState.splitRatio</attribute>
            <attribute name="onSplitRatioChanged.bind">onSplitRatioChanged</attribute>
        </xpath>
    </t>

    <t t-name="diecut.SplitListRenderer">
        <div
            class="o_list_renderer o_renderer o_diecut_split_renderer"
            tabindex="-1"
            t-ref="root"
            t-att-class="{'is-vertical': isVertical and !isListMode, 'is-horizontal': !isVertical and !isListMode, 'is-list-only': isListMode, 'is-resizing': state.resizing, 'hide-split-handle': (props.context and props.context.hide_split_handle) or (props.list and props.list.context and props.list.context.hide_split_handle)}"
            t-att-style="splitLayoutStyle"
        >
            <t t-if="showNoContentHelper">
                <ActionHelper noContentHelp="props.noContentHelp" showRibbon="props.list.model.useSampleModel"/>
            </t>

            <div class="o_diecut_split_left">
                <table t-attf-class="o_list_table table table-sm table-hover position-relative mb-0 {{props.list.isGrouped ? 'o_list_table_grouped' : 'o_list_table_ungrouped table-striped'}}" t-ref="table">
                    <thead>
                        <tr>
                            <th t-if="hasSelectors" class="o_list_record_selector o_list_controller align-middle pe-1 cursor-pointer" tabindex="-1" t-on-keydown="(ev) => this.onCellKeydown(ev)" t-on-click.stop="toggleSelection">
                                <CheckBox disabled="!canSelectRecord" value="selectAll" className="'d-flex m-0'" onChange.bind="toggleSelection"/>
                            </th>
                            <t t-foreach="columns" t-as="column" t-key="column.id">
                                <th t-if="column.type === 'field'"
                                    t-att-data-name="column.name"
                                    t-att-class="getColumnClass(column) + ' opacity-trigger-hover w-print-auto'"
                                    t-on-pointerup="onColumnTitleMouseUp"
                                    t-on-click="() => this.onClickSortColumn(column)"
                                    t-on-keydown="(ev) => this.onCellKeydown(ev)"
                                    data-tooltip-delay="1000"
                                    tabindex="-1">
                                    <t t-if="column.hasLabel and column.widget !== 'handle'">
                                        <t t-set="isNumeric" t-value="isNumericColumn(column)"/>
                                        <div class="d-flex align-items-center"
                                            t-att-data-tooltip-template="isDebugMode ? 'web.FieldTooltip' : 'web.ListHeaderTooltip'"
                                            t-att-data-tooltip-info="makeTooltip(column)">
                                            <span class="d-block min-w-0 text-truncate flex-grow-1 flex-shrink-1" t-att-class="isNumeric ? 'o_list_number_th' : ''" t-esc="column.label"/>
                                            <div class="o_list_header_label_spacer"/>
                                            <i class="o_list_sortable_icon" t-att-class="getSortableIconClass(column)"/>
                                        </div>
                                        <span class="o_resize position-absolute top-0 end-0 bottom-0 ps-1 bg-black-25 opacity-0 opacity-50-hover z-1"
                                            t-on-pointerdown.stop.prevent="this.columnWidths.onStartResize"
                                            t-on-dblclick="this.columnWidths.resetWidths"/>
                                    </t>
                                </th>
                                <th t-else="" t-on-keydown="(ev) => this.onCellKeydown(ev)" t-att-class="{'o_list_button w-print-0 p-print-0': column.type === 'button_group'}"/>
                            </t>
                            <th t-if="hasOpenFormViewColumn" t-on-keydown="(ev) => this.onCellKeydown(ev)" class="o_list_open_form_view w-print-0 p-print-0"/>
                            <th t-if="hasActionsColumn" t-on-keydown="(ev) => this.onCellKeydown(ev)" class="o_list_controller o_list_actions_header w-print-0 p-print-0 position-sticky end-0">
                                <div t-if="displayOptionalFields or hasOptionalOpenFormViewColumn" class="o_optional_columns_dropdown d-print-none text-center border-top-0">
                                    <Dropdown position="'bottom-end'">
                                        <button class="btn p-0" tabindex="-1">
                                            <i class="o_optional_columns_dropdown_toggle oi oi-fw oi-settings-adjust"/>
                                        </button>
                                        <t t-set-slot="content">
                                            <t t-foreach="optionalFieldGroups" t-as="group" t-key="group_index">
                                                <div t-if="!group_first" role="separator" class="dropdown-divider"/>
                                                <DropdownItem t-if="group.displayName" closingMode="'none'" onSelected="() => this.toggleOptionalFieldGroup(group.id)">
                                                    <div class="fw-bold" t-esc="group.displayName"/>
                                                </DropdownItem>
                                                <t t-foreach="group.optionalFields" t-as="field" t-key="field_index">
                                                    <DropdownItem closingMode="'none'" onSelected="() => this.toggleOptionalField(field.name)">
                                                        <CheckBox onChange="() => this.toggleOptionalField(field.name)" value="field.value" name="field.name">
                                                            <span class="d-flex align-items-center"><span class="text-truncate" t-esc="field.label"/><span class="ps-1" t-if="env.debug" t-esc="' (' + field.name + ')'"/></span>
                                                        </CheckBox>
                                                    </DropdownItem>
                                                </t>
                                            </t>
                                        </t>
                                    </Dropdown>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="ui-sortable">
                        <t t-call="web.ListRenderer.Rows">
                            <t t-set="list" t-value="props.list"/>
                        </t>
                    </tbody>
                </table>
            </div>

            <div t-if="!isListMode" class="o_diecut_split_handle" t-att-class="isVertical ? 'is-vertical' : 'is-horizontal'" t-on-mousedown="startResize">
                <span class="o_diecut_split_handle_grip" aria-hidden="true"/>
            </div>

            <aside t-if="!isListMode" class="o_diecut_split_panel position-relative">
                <t t-if="formViewProps">
                    <div class="o_diecut_split_panel_form">
                        <div t-if="isKnowledgeModel" class="o_diecut_split_breadcrumb_bar">
                            <span class="o_diecut_split_breadcrumb_label">页面路径:</span>
                            <t t-if="kbBreadcrumbsLoading">
                                <span class="o_diecut_split_breadcrumb_item text-muted">加载中...</span>
                            </t>
                            <t t-else="">
                                <t t-if="kbBreadcrumbs.length">
                                    <t t-foreach="kbBreadcrumbs" t-as="crumb" t-key="crumb_index">
                                        <span class="o_diecut_split_breadcrumb_item" t-esc="crumb"/>
                                        <span t-if="!crumb_last" class="o_diecut_split_breadcrumb_sep">/</span>
                                    </t>
                                </t>
                            </t>
                        </div>
                        <View t-key="effectiveSelectedResId" t-props="formViewProps"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="o_diecut_split_panel_empty d-flex flex-column align-items-center gap-3">
                        <span t-esc="isKnowledgeModel ? '请先在左侧选择一个知识页面以加载右侧内容' : '请先在左侧选择一个型号以加载右侧表单'"/>
                        <button t-if="!isKnowledgeModel" class="btn btn-primary btn-sm" type="button" t-on-click="createNewRecord">
                            <i class="fa fa-plus me-1"/>
                            <span>新建型号</span>
                        </button>
                    </div>
                </t>
            </aside>
        </div>
    </t>
</templates>
