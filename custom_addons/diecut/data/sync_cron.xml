<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_materials_to_products" model="ir.cron">
            <field name="name">Sync Materials to Products (One Time)</field>
            <field name="model_id" ref="model_my_material" />
            <field name="state">code</field>
            <field name="code">model.action_sync_all_products()</field>
            <field name="user_id" ref="base.user_root" />
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True" />
        </record>
    </data>
</odoo>