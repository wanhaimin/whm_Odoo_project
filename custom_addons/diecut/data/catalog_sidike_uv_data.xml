<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- ======================================================= -->
        <!-- 1. 创建 UV 失粘胶带系列的属性值（复用"型号"属性）         -->
        <!-- ======================================================= -->
        <record id="attr_val_sdk2200uv" model="product.attribute.value">
            <field name="name">SDK2200UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">101</field>
        </record>

        <record id="attr_val_sdk2409uv" model="product.attribute.value">
            <field name="name">SDK2409UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">102</field>
        </record>

        <record id="attr_val_sdk2200uv_p3" model="product.attribute.value">
            <field name="name">SDK2200UV-P-3</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">103</field>
        </record>

        <record id="attr_val_sdk2408uv" model="product.attribute.value">
            <field name="name">SDK2408UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">104</field>
        </record>

        <record id="attr_val_sdk2302uv" model="product.attribute.value">
            <field name="name">SDK2302UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">105</field>
        </record>

        <record id="attr_val_sdk2100uv" model="product.attribute.value">
            <field name="name">SDK2100UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">106</field>
        </record>

        <record id="attr_val_sdk2304_1uv" model="product.attribute.value">
            <field name="name">SDK2304-1UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">107</field>
        </record>

        <record id="attr_val_sdk99853uv_f" model="product.attribute.value">
            <field name="name">SDK99853UV-F</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">108</field>
        </record>

        <record id="attr_val_sdk925au" model="product.attribute.value">
            <field name="name">SDK925AU</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">109</field>
        </record>

        <record id="attr_val_sdk925au_3k" model="product.attribute.value">
            <field name="name">SDK925AU(三抗)</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">110</field>
        </record>

        <record id="attr_val_sdk9212uv" model="product.attribute.value">
            <field name="name">SDK9212UV</field>
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="sequence">111</field>
        </record>
        <!-- ======================================================= -->
        <!-- 2. 创建选型目录产品模板：Sidike UV失粘胶带系列            -->
        <!-- ======================================================= -->
        <record id="catalog_sidike_uv" model="product.template">
            <field name="name">Sidike UV失粘胶带系列</field>
            <field name="is_catalog">True</field>
            <field name="catalog_status">published</field>
            <field name="categ_id" ref="category_tape_uv_debonding" />
            <field name="catalog_base_material">PET/PO/PVC</field>
            <field name="catalog_adhesive_type">特殊亚克力胶</field>
            <field name="catalog_features">UV失粘胶带采用特殊设计和配方，在受到紫外光辐射后可自动减粘，从粘贴表面脱离
适合各种临时保护，用完减粘解离的粘接应用，如制程中的临时固定或表面保护等</field>
            <field name="catalog_applications">UV失粘过程：临时固定 → 紫外光照射 → 自动减粘脱离
制程中的临时固定或表面保护</field>
            <field name="series_name">UV Debonding Tape</field>
            <field name="purchase_ok">False</field>
            <field name="sale_ok">False</field>
            <field name="type">consu</field>
        </record>
        <!-- ======================================================= -->
        <!-- 3. 创建属性线：将"型号"属性关联到 UV 模板                -->
        <!-- ======================================================= -->
        <record id="catalog_sidike_uv_attr_line" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="catalog_sidike_uv" />
            <field name="attribute_id" ref="attribute_model_sku" />
            <field name="value_ids" eval="[
                Command.link(ref('attr_val_sdk2200uv')),
                Command.link(ref('attr_val_sdk2409uv')),
                Command.link(ref('attr_val_sdk2200uv_p3')),
                Command.link(ref('attr_val_sdk2408uv')),
                Command.link(ref('attr_val_sdk2302uv')),
                Command.link(ref('attr_val_sdk2100uv')),
                Command.link(ref('attr_val_sdk2304_1uv')),
                Command.link(ref('attr_val_sdk99853uv_f')),
                Command.link(ref('attr_val_sdk925au')),
                Command.link(ref('attr_val_sdk925au_3k')),
                Command.link(ref('attr_val_sdk9212uv')),
            ]" />
        </record>
        <!-- ======================================================= -->
        <!-- 4. 填充变体技术参数（通过 Python 方法避免 XML 转义问题） -->
        <!-- ======================================================= -->
        <function model="product.product" name="_load_sidike_uv_variant_data" />
    </data>
</odoo>