<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 打样订单序列号 -->
    <record id="sequence_sample_order" model="ir.sequence">
        <field name="name">Sample Order Sequence</field>
        <field name="code">sample.order</field>
        <field name="prefix">SO%(year)s%(month)s</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
    <!-- Sequence for Material Code (Merged from my_material_list) -->
    <record id="seq_my_material" model="ir.sequence">
        <field name="name">Material Code</field>
        <field name="code">my.material.code</field>
        <field name="prefix">MAT</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False" />
    </record>
    <!-- 模切报价单序列号 -->
    <record id="sequence_diecut_quote" model="ir.sequence">
        <field name="name">Diecut Quote Sequence</field>
        <field name="code">diecut.quote</field>
        <field name="prefix">SZ%(year)s%(month)s%(day)s</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False" />
    </record>
</odoo>