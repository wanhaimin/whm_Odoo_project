<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_diecut_catalog_spec_bulk_add_wizard_form" model="ir.ui.view">
        <field name="name">diecut.catalog.spec.bulk.add.wizard.form</field>
        <field name="model">diecut.catalog.spec.bulk.add.wizard</field>
        <field name="arch" type="xml">
            <form string="批量添加分类参数">
                <sheet>
                    <group>
                        <group>
                            <field name="categ_id"/>
                            <field name="spec_category_filter_id"/>
                            <field name="search_term" placeholder="输入参数名称或参数键"/>
                        </group>
                        <group>
                            <field name="available_param_count" readonly="1"/>
                            <div class="o_form_label">默认模板</div>
                            <div>
                                <span class="text-muted">必填=否，表单显示=是，允许导入=是，启用=是，序号自动追加</span>
                            </div>
                        </group>
                    </group>

                    <group string="待添加参数">
                        <field name="param_ids" domain="[('id', 'in', available_param_ids)]" options="{'no_create': True, 'no_create_edit': True}">
                            <list string="待添加参数">
                                <field name="name"/>
                                <field name="param_key"/>
                                <field name="spec_category_id"/>
                                <field name="value_type"/>
                                <field name="preferred_unit"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="确认添加" class="btn btn-primary"/>
                    <button string="取消" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
