<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catalog_shadow_health_wizard_form" model="ir.ui.view">
        <field name="name">diecut.catalog.shadow.health.wizard.form</field>
        <field name="model">diecut.catalog.shadow.health.wizard</field>
        <field name="arch" type="xml">
            <form string="新架构影子健康检查" create="0" edit="0" delete="0">
                <group>
                    <group>
                        <field name="legacy_model_count" />
                        <field name="shadow_model_count" />
                        <field name="missing_shadow_count" />
                    </group>
                    <group>
                        <field name="duplicate_brand_code_count" />
                        <field name="orphan_model_count" />
                    </group>
                </group>
                <group>
                    <p class="text-muted">
                        健康标准：缺失影子记录=0，品牌+编码重复组=0，孤儿型号=0。
                    </p>
                </group>
                <footer>
                    <button name="action_refresh" string="刷新" type="object" class="btn-primary" />
                    <button name="action_open_integrity_issues" string="查看结构异常" type="object" class="btn-secondary" />
                    <button string="关闭" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_catalog_shadow_health_wizard" model="ir.actions.act_window">
        <field name="name">迁移健康检查</field>
        <field name="res_model">diecut.catalog.shadow.health.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_catalog_shadow_health_wizard_form" />
        <field name="target">new</field>
    </record>
</odoo>
