<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catalog_param_mass_edit_wizard_form" model="ir.ui.view">
        <field name="name">diecut.catalog.param.mass.edit.wizard.form</field>
        <field name="model">diecut.catalog.param.mass.edit.wizard</field>
        <field name="arch" type="xml">
            <form string="批量处理参数">
                <sheet>
                    <group>
                        <group>
                            <field name="param_id" readonly="1"/>
                            <field name="operation"/>
                        </group>
                        <group>
                            <field name="target_count" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="not result_message">
                        <field name="result_message" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_execute" type="object" string="确认执行" class="btn-primary"/>
                    <button string="取消" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_server_catalog_param_mass_edit" model="ir.actions.server">
        <field name="name">按当前参数批量增删</field>
        <field name="model_id" ref="model_diecut_catalog_item"/>
        <field name="binding_model_id" ref="model_diecut_catalog_item"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_param_mass_edit_wizard()</field>
    </record>
</odoo>
