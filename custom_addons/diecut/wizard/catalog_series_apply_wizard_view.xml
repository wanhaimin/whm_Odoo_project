<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_catalog_series_apply_wizard_form" model="ir.ui.view">
        <field name="name">diecut.catalog.series.apply.wizard.form</field>
        <field name="model">diecut.catalog.series.apply.wizard</field>
        <field name="arch" type="xml">
            <form string="应用系列模板">
                <sheet>
                    <group>
                        <field name="catalog_item_id" readonly="1"/>
                        <field name="apply_mode"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" string="确认应用" type="object" class="btn-primary"/>
                    <button string="取消" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
