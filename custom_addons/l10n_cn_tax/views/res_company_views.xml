<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend company form: add CN taxpayer config in a dedicated tab -->
    <record id="view_company_form_cn_tax" model="ir.ui.view">
        <field name="name">res.company.form.cn.tax</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="中国税务配置" name="cn_tax_config">
                    <group string="增值税">
                        <field name="cn_taxpayer_type"/>
                    </group>
                    <group string="附加税">
                        <field name="cn_city_tax_rate"/>
                    </group>
                    <group string="企业所得税">
                        <field name="cn_is_small_profit"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
